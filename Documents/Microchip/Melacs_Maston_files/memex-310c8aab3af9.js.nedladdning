  position: relative;
  &:after,
  &:before {
    content: '';
    display: none;
    position: absolute;
    top: -${(0,cB.U2)("space.2")};
    width: ${(0,cB.U2)("space.1")};
    background-color: ${(0,cB.U2)("colors.accent.emphasis")};
    height: calc(100% + ${(0,cB.U2)("space.3")});
    border: 0;
    border-radius: 6px;
    z-index: 12;
  }

  body.is-dragging &.show-sash-view.show-sash-after {
    &::after {
      right: -20px;
      display: block;
    }

    &.selected::after {
      right: -20px;
    }
  }

  body.is-dragging &.show-sash-view.show-sash-before {
    &::before {
      left: -18px;
      display: block;
    }
    &.selected::before {
      right: -21px;
