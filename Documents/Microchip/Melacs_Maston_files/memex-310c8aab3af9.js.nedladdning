  position: relative;

  &:after,
  &:before {
    content: '';
    display: none;
    position: absolute;
    left: 0;
    right: 0;
    background-color: ${(0,cB.U2)("colors.accent.emphasis")};
    height: ${(0,cB.U2)("space.1")};
    border: 0;
    border-radius: 6px;
    z-index: 12;
  }

  body.is-dragging &.show-sash-singleSelectItem.show-sash-after {
    &:after {
      display: block;
      bottom: 0;
      transform: translateY(50%);
    }
  }

  body.is-dragging &.show-sash-singleSelectItem.show-sash-before {
    &:before {
      display: block;
      top: 0;
      transform: translateY(-50%);
