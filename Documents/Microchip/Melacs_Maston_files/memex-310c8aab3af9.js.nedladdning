  scroll-margin-top: 35px; /* Account for sticky header */
  scroll-margin-bottom: 64px; /* Account for sticky footer */
  cursor: default;
  border-left: 1px solid ${(0,cB.U2)("colors.border.muted")};
  border-bottom: 1px solid ${(0,cB.U2)("colors.border.muted")};
  outline: none;

  &:first-of-type {
    border-left: none;
  }

  &:nth-of-type(2) {
    border-left: none;
  }

  &:last-child {
    border-right: none;
  }

  .row-highlight &.hoverable:hover {
    background-color: unset;
  }

  &.is-copy-source {
    border: 2px dashed ${(0,cB.U2)("colors.accent.emphasis")};
  }

  &.is-focused {
    position: relative;
    overflow-x: visible !important;
    overflow-y: visible;

    :before {
      content: '';
      position: absolute;
      width: calc(100% - 2px);
      height: calc(100% - 2px);
      border: 2px solid ${(0,cB.U2)("colors.accent.emphasis")};
      border-radius: 2px;
      left: -1px;
      top: -1px;
      z-index: 0;
      box-shadow: inset -3px 0 0 0 ${(0,cB.U2)("colors.canvas.default")},
        inset 0 -3px 0 0 ${(0,cB.U2)("colors.canvas.default")}, inset 3px 0 0 0 ${(0,cB.U2)("colors.canvas.default")},
        inset 0 3px 0 0 ${(0,cB.U2)("colors.canvas.default")}, ${(0,cB.U2)("shadows.shadow.medium")};
      pointer-events: none;
    }

    /* NOTE: Lower-right handle for bulk cell selection (commented because we haven't shipped that, yet) */

    /* :after {
       content: '';
       position: absolute;
       width: 7px;
       height: 7px;
       border: 2px solid ${(0,cB.U2)("colors.fg.onEmphasis")};
       right: -6px;
       bottom: -6px;
       background-color: ${(0,cB.U2)("colors.accent.subtle")};
       z-index: 2;
       cursor: crosshair;
     } */
  }

  &.is-focused.is-first-row {
    :before {
      top: 0px;
      height: calc(100% - 3px);
    }
  }

  &.is-focused.is-editing {
    background-color: ${(0,cB.U2)("colors.canvas.default")};
    :before {
      box-shadow: inset -3px 0 0 0 ${(0,cB.U2)("colors.canvas.default")},
        inset 0 -3px 0 0 ${(0,cB.U2)("colors.canvas.default")}, inset 3px 0 0 0 ${(0,cB.U2)("colors.canvas.default")},
        inset 0 3px 0 0 ${(0,cB.U2)("colors.canvas.default")}, ${(0,cB.U2)("shadows.shadow.medium")};
    }

    :after {
      display: none;
    }
  }

  &.is-focused.is-invalid {
    :before {
      border-color: ${(0,cB.U2)("colors.danger.fg")};
    }
  }

  &.is-focused.cursor-not-allowed {
    :before {
      border: 2px solid ${(0,cB.U2)("colors.neutral.muted")};
      box-shadow: none;
    }
  }

  &.cursor-not-allowed {
    cursor: not-allowed;
  }

  &.draggable {
    cursor: grab;
    user-select: none;
  }

  &.draggable:active,
  &.is-dragging {
    cursor: grabbing;
    user-select: none;
  }

  .reveal-link-icon {
    visibility: hidden;
  }

  &:hover .reveal-link-icon {
    visibility: visible;
  }
`,Qt=cG.ZP.div`
