1770:              		ADC_T2_Mean = Loc_T2_Mean / BSP_SETTINGS_ADC_X32_SIG_SAMPLES;
1771:              		Loc_T2_Mean = 0;
1772:              		// T3
1773:              		ADC_T3_Mean = Loc_T3_Mean / BSP_SETTINGS_ADC_X32_SIG_SAMPLES;
1774:              		Loc_T3_Mean = 0;
1775:              		// AUX4
1776:              		ADC_AUX4_Mean = Loc_AUX4_Mean / BSP_SETTINGS_ADC_X32_SIG_SAMPLES;
1777:              		Loc_AUX4_Mean = 0;
1778:              		// Reset flag
1779:              		Loc_x32_Busy = false;
1780:              		if(Loc_x32_CntDwn > 0) {
1781:              			if(Loc_x32_CntDwn == 1) {
1782:              				if((Loc_x1_CntDwn == 0) &&
1783:              					(Loc_x8_CntDwn == 0) &&
1784:              					(Loc_x16_CntDwn == 0)) {
1785:              						ADC_Ready = true;
1786:              						ADC_Save_to_NVM();
1787:              				}
1788:              			}
1789:              			Loc_x32_CntDwn--;
1790:              		}
1791:              	}
1792:              }
1793:              #else	// HARDWARE_VERSION_x
1794:              #error HARDWARE_VERSION_x not defined
1795:              #endif	// HARDWARE_VERSION_x
