                                                  34:    
                                                  35:            ; Local inclusions.
                                                  36:            .nolist
                                                  37:            .include        "dspcommon.inc"         ; fractsetup
                                                  38:            .list
                                                  39:    
                                                  40:            .equ    offsetabcCoefficients, 0
                                                  41:            .equ    offsetcontrolHistory, 2
                                                  42:            .equ    offsetcontrolOutput, 4
                                                  43:            .equ    offsetmeasuredOutput, 6
                                                  44:            .equ    offsetcontrolReference, 8
                                                  45:    
                                                  46:    ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
                                                  47:    
                                                  48:            .section .libdsp, code
                                                  49:    
                                                  50:    ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
                                                  51:    ;
                                                  52:    ; _PID:
                                                  53:    ; Prototype:
                                                  54:    ;              tPID PID ( tPID *fooPIDStruct )
                                                  55:    ;
                                                  56:    ; Operation:
                                                  57:    ;
                                                  58:    ;                                             ----   Proportional
                                                  59:    ;                                            |    |  Output
                                                  60:    ;                             ---------------| Kp |-----------------
                                                  61:    ;                            |               |    |                 |
                                                  62:    ;                            |                ----                  |
                                                  63:    ;Reference                   |                                     ---
                                                  64:    ;Input         ---           |           --------------  Integral | + | Control   -------
                                                  65:    ;     --------| + |  Control |          |      Ki      | Output   |   | Output   |       |
                                                  66:    ;             |   |----------|----------| ------------ |----------|+  |----------| Plant |--
                                                  67:    ;        -----| - |Difference|          |  1 - Z^(-1)  |          |   |          |       |  |
                                                  68:    ;       |      ---  (error)  |           --------------           | + |           -------   |
                                                  69:    ;       |                    |                                     ---                      |
                                                  70:    ;       | Measured           |         -------------------  Deriv   |                       |
                                                  71:    ;       | Outut              |        |                   | Output  |                       |
                                                  72:    ;       |                     --------| Kd * (1 - Z^(-1)) |---------                        |
                                                  73:    ;       |                             |                   |                                 |
                                                  74:    ;       |                              -------------------                                  |
                                                  75:    ;       |                                                                                   |
                                                  76:    ;       |                                                                                   |
                                                  77:    ;        -----------------------------------------------------------------------------------
                                                  78:    ;
                                                  79:    ;   controlOutput[n] = controlOutput[n-1]
                                                  80:    ;                    + controlHistory[n] * abcCoefficients[0]
                                                  81:    ;                    + controlHistory[n-1] * abcCoefficients[1]
                                                  82:    ;                    + controlHistory[n-2] * abcCoefficients[2]
                                                  83:    ;
                                                  84:    ;  where:
                                                  85:    ;   abcCoefficients[0] = Kp + Ki + Kd
                                                  86:    ;   abcCoefficients[1] = -(Kp + 2*Kd)
                                                  87:    ;   abcCoefficients[2] = Kd
                                                  88:    ;   controlHistory[n] = measuredOutput[n] - referenceInput[n]
                                                  89:    ;  where:
                                                  90:    ;   abcCoefficients, controlHistory, controlOutput, measuredOutput and controlReference
                                                  91:    ;   are all members of the data structure tPID.
                                                  92:    ;
                                                  93:    ; Input:
                                                  94:    ;       w0 = Address of tPID data structure
                                                  95:    
                                                  96:    ; Return:
                                                  97:    ;       w0 = Address of tPID data structure
                                                  98:    ;
                                                  99:    ; System resources usage:
                                                  100:   ;       {w0..w5}        used, not restored
                                                  101:   ;       {w8,w10}        saved, used, restored
                                                  102:   ;        AccA, AccB     used, not restored
                                                  103:   ;        CORCON         saved, used, restored
                                                  104:   ;
                                                  105:   ; DO and REPEAT instruction usage.
                                                  106:   ;       0 level DO instruction
                                                  107:   ;       0 REPEAT intructions
                                                  108:   ;
                                                  109:   ; Program words (24-bit instructions):
                                                  110:   ;       28
                                                  111:   ;
                                                  112:   ; Cycles (including C-function call and return overheads):
                                                  113:   ;       30
                                                  114:   ;............................................................................
                                                  115:   
                                                  116:           .global _PID                    ; provide global scope to routine
                                                  117:   _PID:
                                                  118:           ;btg LATD, #1
                                                  119:           ; Save working registers.
000622  FEA000     PUSH.S                         120:           push.s
000624  781F84     MOV W4, [W15++]                121:           push    w4
000626  781F85     MOV W5, [W15++]                122:           push    w5        
000628  781F88     MOV W8, [W15++]                123:           push    w8
00062A  781F8A     MOV W10, [W15++]               124:           push    w10
                                                  125:   
                                                  126:           
00062C  F80044     PUSH CORCON                    127:           push    CORCON                  ; Prepare CORCON for fractional computation.
                                                  128:   
                                                  129:   
00062E  200F08     MOV #0xF0, W8                  130:           fractsetup      w8
                                                  131:   
000632  900400     MOV [W0+0], W8                 132:           mov [w0 + #offsetabcCoefficients], w8    ; w8 = Base Address of _abcCoefficients array [(Kp+Ki+Kd), -(Kp+2Kd), Kd]
000634  900510     MOV [W0+2], W10                133:           mov [w0 + #offsetcontrolHistory], w10    ; w10 = Address of _ControlHistory array (state/delay line)
                                                  134:   
000636  9000A0     MOV [W0+4], W1                 135:           mov [w0 + #offsetcontrolOutput], w1
000638  900130     MOV [W0+6], W2                 136:           mov [w0 + #offsetmeasuredOutput], w2
00063A  9001C0     MOV [W0+8], W3                 137:           mov [w0 + #offsetcontrolReference], w3
                                                  138:   
                                                  139:           ; Calculate most recent error with saturation, no limit checking required
00063C  CA0003     LAC W3, A                      140:           lac     w3, a                   ; A = tPID.controlReference
00063E  CA8002     LAC W2, B                      141:           lac     w2, b                   ; B = tPID.MeasuredOutput
000640  CB3000     SUB A                          142:           sub     a                       ; A = tPID.controlReference - tPID.measuredOutput
000642  CD001A     SAC.R A, [W10]                 143:           sac.r   a, [w10]                ; tPID.ControlHistory[n] = Sat(Rnd(A))
                                                  144:   
                                                  145:           ; Calculate PID Control Output
000644  C30446     CLR A, [W8]+=2, W4, [W10]+=2, W5146:           clr     a, [w8]+=2, w4, [w10]+=2, w5            ; w4 = (Kp+Ki+Kd), w5 = _ControlHistory[n]
000646  CA0001     LAC W1, A                      147:           lac     w1, a                                   ; A = ControlOutput[n-1]
000648  C00446     MAC W4*W5, A, [W8]+=2, W4, [W10]+=2, W5148:           mac     w4*w5, a, [w8]+=2, w4, [w10]+=2, w5     ; A += (Kp+Ki+Kd) * _ControlHistory[n]
                                                  149:                                                           ; w4 = -(Kp+2Kd), w5 = _ControlHistory[n-1]
00064A  C0041E     MAC W4*W5, A, [W8], W4, [W10]-=2, W5150:           mac     w4*w5, a, [w8], w4, [w10]-=2, w5        ; A += -(Kp+2Kd) * _ControlHistory[n-1]
                                                  151:                                                           ; w4 = Kd, w5 = _ControlHistory[n-2]
00064C  C00506     MAC W4*W5, A, [W10]+=2, W5     152:           mac     w4*w5, a, [w10]+=2, w5                  ; A += Kd * _ControlHistory[n-2]
                                                  153:                                                           ; w5 = _ControlHistory[n-1]
                                                  154:                                                           ; w10 = &_ControlHistory[n-2]
00064E  CD0001     SAC.R A, W1                    155:           sac.r   a, w1                                   ; ControlOutput[n] = Sat(Rnd(A))
                                                  156:           
000650  980021     MOV W1, [W0+4]                 157:           mov     w1, [w0 + #offsetcontrolOutput]
                                                  158:   
                                                  159:           ;Update the error history on the delay line
000652  780D05     MOV W5, [W10]                  160:           mov     w5, [w10]               ; _ControlHistory[n-2] = _ControlHistory[n-1]
000654  97BAEA     MOV [W10-4], W5                161:           mov     [w10 + #-4], w5         ; _ControlHistory[n-1] = ControlHistory[n]
000656  782505     MOV W5, [--W10]                162:           mov     w5, [--w10]
                                                  163:   
000658  F90044     POP CORCON                     164:           pop     CORCON                  ; restore CORCON.
00065A  78054F     MOV [--W15], W10               165:           pop     w10                     ; Restore working registers.
00065C  78044F     MOV [--W15], W8                166:           pop     w8
00065E  7802CF     MOV [--W15], W5                167:           pop     w5
000660  78024F     MOV [--W15], W4                168:           pop     w4
000662  FE8000     POP.S                          169:           pop.s
                                                  170:          ; bclr LATD, #1        
000664  060000     RETURN                         171:           return
                                                  172:   
                                                  173:   ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
                                                  174:   
                                                  175:   ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
                                                  176:   ; _PIDInit:
                                                  177:   ;
                                                  178:   ; Prototype:
                                                  179:   ; void PIDInit ( tPID *fooPIDStruct )
                                                  180:   ;
                                                  181:   ; Operation: This routine clears the delay line elements in the array
                                                  182:   ;            _ControlHistory, as well as clears the current PID output
                                                  183:   ;            element, _ControlOutput
                                                  184:   ;
                                                  185:   ; Input:
                                                  186:   ;       w0 = Address of data structure tPID (type defined in dsp.h)
                                                  187:   ;
                                                  188:   ; Return:
                                                  189:   ;       (void)
                                                  190:   ;
                                                  191:   ; System resources usage:
                                                  192:   ;       w0             used, restored
                                                  193:   ;
                                                  194:   ; DO and REPEAT instruction usage.
                                                  195:   ;       0 level DO instruction
                                                  196:   ;       0 REPEAT intructions
                                                  197:   ;
                                                  198:   ; Program words (24-bit instructions):
                                                  199:   ;       11
                                                  200:   ;
                                                  201:   ; Cycles (including C-function call and return overheads):
                                                  202:   ;       13
                                                  203:   ;............................................................................
                                                  204:           .global _PIDInit                ; provide global scope to routine
                                                  205:   _PIDInit:
000666  781F80     MOV W0, [W15++]                206:           push    w0
000668  B00040     ADD #0x4, W0                   207:           add     #offsetcontrolOutput, w0 ;clear controlOutput
00066A  EB0800     CLR [W0]                       208:           clr     [w0]
00066C  78004F     MOV [--W15], W0                209:   	pop	w0
00066E  781F80     MOV W0, [W15++]                210:   	push	w0
                                                  211:                                           ;Set up pointer to the base of
                                                  212:                                           ;controlHistory variables within tPID
000670  900010     MOV [W0+2], W0                 213:           mov     [w0 + #offsetcontrolHistory], w0
                                                  214:                                           ; Clear controlHistory variables
                                                  215:                                           ; within tPID
000672  EB1800     CLR [W0++]                     216:           clr     [w0++]                  ; ControlHistory[n]=0
000674  EB1800     CLR [W0++]                     217:           clr     [w0++]                  ; ControlHistory[n-1] = 0
000676  EB0800     CLR [W0]                       218:           clr     [w0]                    ; ControlHistory[n-2] = 0
000678  78004F     MOV [--W15], W0                219:           pop     w0                      ;Restore pointer to base of tPID
00067A  060000     RETURN                         220:           return
                                                  221:   
                                                  222:   ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
                                                  223:   
                                                  224:           .end
                                                  225:   
                                                  226:   ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
