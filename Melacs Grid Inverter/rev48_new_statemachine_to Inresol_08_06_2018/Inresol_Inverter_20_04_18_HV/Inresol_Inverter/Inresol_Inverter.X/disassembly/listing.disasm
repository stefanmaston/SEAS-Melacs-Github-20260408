729:               #if (BSP_UART_2_RX_RB_SIZE != 0)
730:               // UART receive-only interrupt handler for ring buffers
731:               static void BSP_UART_2_Rx_IntHandlerRB(void)
732:               {
733:               	// Read the receive buffer until at least one or more character can be read
734:               	// New data will be ignored if data not popped in time
735:               	while(DataRdyUART2()) {
736:               		uint8_t ch = ReadUART2();
737:               		RingBuffer_Insert(&Uart_2_Rx_Ring, &ch);
738:               	}
739:               }
740:               #endif
741:               
742:               #if (BSP_UART_2_TX_RB_SIZE != 0)
743:               // UART transmit-only interrupt handler for ring buffers
744:               static void BSP_UART_2_Tx_IntHandlerRB(void)
745:               {
746:               	uint8_t ch;
747:               
748:               	// Fill FIFO until full or until TX ring buffer is empty
749:               	while((U2STAbits.UTXBF == 0) && RingBuffer_Pop(&Uart_2_Tx_Ring, &ch)) {
750:               		WriteUART2(ch);
751:               	}
752:               }
753:               #endif
