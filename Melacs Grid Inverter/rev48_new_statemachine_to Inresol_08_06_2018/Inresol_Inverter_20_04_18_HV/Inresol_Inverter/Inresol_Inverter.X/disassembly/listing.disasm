71:                uint16_t App_OCP_Get_Sample_Scaled(uint8_t Channel)
72:                {
00CAF0  FA0004     LNK #0x4
00CAF2  984720     MOV.B W0, [W14+2]
73:                	uint16_t	sample_value;
74:                
75:                	switch(Channel) {
00CAF4  90402E     MOV.B [W14+2], W0
00CAF6  FB8000     ZE W0, W0
00CAF8  E00000     CP0 W0
00CAFA  320003     BRA Z, 0xCB02
00CAFC  500FE1     SUB W0, #0x1, [W15]
00CAFE  320004     BRA Z, 0xCB08
00CB00  370006     BRA 0xCB0E
76:                		case APP_OCP_ITRIP_CHANNEL_NUMBER_1:
77:                			sample_value = App_OCP_Get_Sample_Scaled_Ch1();
00CB02  07FFE6     RCALL App_OCP_Get_Sample_Scaled_Ch1
00CB04  780F00     MOV W0, [W14]
78:                			break;
00CB06  370003     BRA 0xCB0E
79:                		case APP_OCP_ITRIP_CHANNEL_NUMBER_2:
80:                			sample_value = App_OCP_Get_Sample_Scaled_Ch2();
00CB08  07FFEB     RCALL App_OCP_Get_Sample_Scaled_Ch2
00CB0A  780F00     MOV W0, [W14]
81:                			break;
00CB0C  000000     NOP
82:                	}
83:                	return sample_value;
00CB0E  78001E     MOV [W14], W0
84:                }
00CB10  FA8000     ULNK
00CB12  060000     RETURN
