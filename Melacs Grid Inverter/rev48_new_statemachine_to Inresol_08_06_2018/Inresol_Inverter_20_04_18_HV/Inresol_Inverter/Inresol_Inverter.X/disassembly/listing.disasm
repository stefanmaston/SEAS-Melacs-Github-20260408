22:                void BSP_System_OSC_Switch(void)
23:                {
00D7C8  FA0000     LNK #0x0
24:                	// Change oscillator to FRC + PLL
25:                #ifndef USE_FRC_CLOCK
26:                	// Setup the uC to use the external crystal with the PLL
27:                	__builtin_write_OSCCONH(0x03);		// New Oscillator FRC w/ PLL
28:                	__builtin_write_OSCCONL(0x01);		// Enable Clock Switch
29:                	while(OSCCONbits.COSC != 0b011);	// Wait for new Oscillator to become FRC w/ PLL
30:                	while(OSCCONbits.LOCK != 1);		// Wait for Pll to Lock
31:                #else    // USE_FRC_CLOCK
32:                	// Setup the uC to use the internal FRCPLL mode
33:                	__builtin_write_OSCCONH(0x01);		// New Oscillator FRC w/ PLL
00D7CA  200012     MOV #0x1, W2
00D7CC  200780     MOV #0x78, W0
00D7CE  2009A1     MOV #0x9A, W1
00D7D0  207433     MOV #0x743, W3
00D7D2  784980     MOV.B W0, [W3]
00D7D4  784981     MOV.B W1, [W3]
00D7D6  784982     MOV.B W2, [W3]
34:                	__builtin_write_OSCCONL(0x01);		// Enable Clock Switch
00D7D8  200012     MOV #0x1, W2
00D7DA  200460     MOV #0x46, W0
00D7DC  200571     MOV #0x57, W1
00D7DE  207423     MOV #0x742, W3
00D7E0  784980     MOV.B W0, [W3]
00D7E2  784981     MOV.B W1, [W3]
00D7E4  784982     MOV.B W2, [W3]
35:                	while(OSCCONbits.COSC != 0b001);	// Wait for new Oscillator to become FRC w/ PLL
00D7E6  000000     NOP
00D7E8  803A11     MOV OSCCON, W1
00D7EA  270000     MOV #0x7000, W0
00D7EC  608080     AND W1, W0, W1
00D7EE  210000     MOV #0x1000, W0
00D7F0  508F80     SUB W1, W0, [W15]
00D7F2  3AFFFA     BRA NZ, 0xD7E8
36:                	while(OSCCONbits.LOCK != 1);		// Wait for PLL to Lock
00D7F4  000000     NOP
00D7F6  803A11     MOV OSCCON, W1
00D7F8  200200     MOV #0x20, W0
00D7FA  608000     AND W1, W0, W0
00D7FC  E00000     CP0 W0
00D7FE  32FFFB     BRA Z, 0xD7F6
37:                #endif   // USE_FRC_CLOCK
38:                }
