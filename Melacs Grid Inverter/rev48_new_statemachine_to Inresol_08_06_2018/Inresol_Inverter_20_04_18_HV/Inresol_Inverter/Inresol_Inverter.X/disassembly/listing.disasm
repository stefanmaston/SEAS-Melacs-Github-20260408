00A40E  780101     MOV W1, W2
00A410  780080     MOV W0, W1
00A412  229B40     MOV #0x29B4, W0
00A414  070A78     RCALL RingBuffer_InsertMult
00A416  90009E     MOV [W14+2], W1
00A418  408000     ADD W1, W0, W0
00A41A  980710     MOV W0, [W14+2]
792:               
793:               	// Enable UART transmit interrupt
794:               	BSP_UART_2_Tx_Interrupt_Enable();
00A41C  07FF62     RCALL BSP_UART_2_Tx_Interrupt_Enable
795:               
796:               	return ret;
00A41E  90001E     MOV [W14+2], W0
