70:                /* ========================================================================= */
71:                #define DO1(buf) crc = crc_table[((int32_t)crc ^ (*buf++)) & 0xff] ^ (crc >> 8);
72:                #define DO2(buf)  DO1(buf); DO1(buf);
73:                #define DO4(buf)  DO2(buf); DO2(buf);
74:                #define DO8(buf)  DO4(buf); DO4(buf);
