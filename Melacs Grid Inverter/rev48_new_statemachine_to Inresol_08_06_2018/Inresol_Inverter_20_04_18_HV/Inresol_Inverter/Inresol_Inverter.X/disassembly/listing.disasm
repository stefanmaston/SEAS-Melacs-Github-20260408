                                                  16:    ; OTHER LEGAL EQUITABLE THEORY ANY DIRECT OR INDIRECT DAMAGES OR EXPENSES
                                                  17:    ; INCLUDING BUT NOT LIMITED TO ANY INCIDENTAL, SPECIAL, INDIRECT, PUNITIVE OR
                                                  18:    ; CONSEQUENTIAL DAMAGES, LOST PROFITS OR LOST DATA, COST OF PROCUREMENT OF
                                                  19:    ; SUBSTITUTE GOODS, TECHNOLOGY, SERVICES, OR ANY CLAIMS BY THIRD PARTIES
                                                  20:    ; (INCLUDING BUT NOT LIMITED TO ANY DEFENSE THEREOF), OR OTHER SIMILAR COSTS.
                                                  21:    ;*********************************************************************************
                                                  22:    
                                                  23:            .include "mc_interfaces_dspic.inc"
                                                  24:    ; Inputs:
                                                  25:    ;  DQ.d
                                                  26:    ;  DQ.q
                                                  27:    ;  SINCOS.cos
                                                  28:    ;  SINCOS.sin
                                                  29:    
                                                  30:    ; Outputs:
                                                  31:    ;  ALPHABETA.alpha
                                                  32:    ;  ALPHABETA.beta
                                                  33:    
                                                  34:    ; Register usage
                                                  35:              .equ workW0,  w0  ; working register
                                                  36:    	      .equ workW1,  w1  ; working register
                                                  37:    	      .equ workW2,  w2  ; working register          
                                                  38:              .equ workW3,  w3  ; working register
                                                  39:              .equ CorconW4,w4  ; CORCON temp
                                                  40:              .equ sinW4,   w4  ; sin
                                                  41:              .equ cosW5,   w5  ; cos
                                                  42:              .equ dW6,     w6  ; d
                                                  43:              .equ qW7,     w7  ; q
                                                  44:    
                                                  45:    ; Note
                                                  46:    ;  This function requires CORCON register to be setup in a certain state
                                                  47:    ;  in order to operate correctly. Due to this requirement, this function
                                                  48:    ;  will save the CORCON register on the stack in the beginning of the
                                                  49:    ;  function and restore it before the function return.
                                                  50:    ;  After saving the CORCON register, this function writes to all bits of
                                                  51:    ;  the CORCON register. Thus, for the brief duration when this function is
                                                  52:    ;  executing, the state of CORCON register may be different from its state
                                                  53:    ;  as set by the function caller. This may change the CPU core behavior with
                                                  54:    ;  respect to exception processing latency, DO loop termination, CPU interrupt
                                                  55:    ;  priority level and DSP-engine behavior.
                                                  56:    
                                                  57:    ;=================== CODE =====================
                                                  58:    
                                                  59:              .section  .text
                                                  60:              .global   _MC_TransformParkInverse_Assembly
                                                  61:              .global   MC_TransformParkInverse_Assembly
                                                  62:    
                                                  63:    _MC_TransformParkInverse_Assembly:
                                                  64:    MC_TransformParkInverse_Assembly:
                                                  65:         ;; Save CORCON, then configure as needed
00DD18  F80044     PUSH CORCON                    66:              push      CORCON
00DD1A  200E24     MOV #0xE2, W4                  67:              mov.w     #0x00E2,CorconW4
00DD1C  880224     MOV W4, CORCON                 68:              mov.w     CorconW4,CORCON
                                                  69:         ;; workW0 : DQ*
                                                  70:    	 ;; workW1 : SINCOS*
                                                  71:    	 ;; workW2 : ALPHABETA*
                                                  72:    	 
                                                  73:         ;; Get d, q from DQ structure
00DD1E  900300     MOV [W0+0], W6                 74:              mov.w     [workW0+DQ_d],dW6
00DD20  900390     MOV [W0+2], W7                 75:              mov.w     [workW0+DQ_q],qW7
                                                  76:    
                                                  77:         ;; Get cos and sine from SINCOS structure
00DD22  900281     MOV [W1+0], W5                 78:              mov.w     [workW1+SINCOS_cos],cosW5
00DD24  900211     MOV [W1+2], W4                 79:              mov.w     [workW1+SINCOS_sin],sinW4
                                                  80:              
                                                  81:         ;; alpha = d*cos(Angle) - q*sin(Angle)
00DD26  C40113     MPY W5*W6, A                   82:              mpy       cosW5*dW6,A     ; Cos*d -> A
00DD28  C24112     MSC W4*W7, A                   83:              msc       sinW4*qW7,A     ; sub Sin*q from A
00DD2A  CC0003     SAC A, W3                      84:              sac       A,workW3        ; store to alpha
00DD2C  980103     MOV W3, [W2+0]                 85:    		  mov.w		workW3,[workW2+ALPHABETA_alpha]
                                                  86:    
                                                  87:         ;; beta = d*sin(Angle) + q*cos(Angle)
00DD2E  C10113     MPY W4*W6, A                   88:              mpy       sinW4*dW6,A     ; Sin*d -> A
00DD30  C50112     MAC W5*W7, A                   89:              mac       cosW5*qW7,A     ; add Cos*q to A
00DD32  CC0003     SAC A, W3                      90:              sac       A,workW3        ; store to beta
00DD34  980113     MOV W3, [W2+2]                 91:    		  mov.w		workW3,[workW2+ALPHABETA_beta]
                                                  92:    
                                                  93:    	 ;; Return 1	  
00DD36  200010     MOV #0x1, W0                   94:    		  mov.w     #1, workW0
00DD38  F90044     POP CORCON                     95:              pop       CORCON
00DD3A  060000     RETURN                         96:              return
                                                  97:              .end
---  C:/Projects/Microchip/Workspace/Inresol_Inverter/lib_src/mc_invclarke_dspic.s  ---------------------
                                                  1:     ;*********************************************************************************
                                                  2:     ; Copyright (c) 2013 released Microchip Technology Inc.  All rights reserved.
                                                  3:     ; Microchip licenses to you the right to use, modify, copy and distribute
                                                  4:     ; Software only when embedded on a Microchip microcontroller or digital signal
                                                  5:     ; controller that is integrated into your product or third party product
