439:               	// Don't let UART transmit ring buffer change in the UART IRQ handler
440:               	BSP_UART_1_Tx_Interrupt_Disable();
00A176  07FF6E     RCALL BSP_UART_1_Tx_Interrupt_Disable
441:               
442:               	// Move as much data as possible into transmit ring buffer
443:               	ret = RingBuffer_InsertMult(&Uart_1_Tx_Ring, p8, length);
00A178  90003E     MOV [W14+6], W0
00A17A  780100     MOV W0, W2
00A17C  78009E     MOV [W14], W1
00A17E  228E00     MOV #0x28E0, W0
00A180  070BC2     RCALL RingBuffer_InsertMult
00A182  980710     MOV W0, [W14+2]
