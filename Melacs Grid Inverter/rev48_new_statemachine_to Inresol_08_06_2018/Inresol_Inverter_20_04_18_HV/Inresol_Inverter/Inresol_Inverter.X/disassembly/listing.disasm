413:               int BSP_UART_1_Send_Data_Blocking(const void  *data, uint16_t length)
414:               {
00A132  FA000A     LNK #0xA
00A134  980730     MOV W0, [W14+6]
00A136  980741     MOV W1, [W14+8]
415:               	//
416:               	// Message sent using blocking method (prevent ring buffer overflow)
417:               	//
418:               	int pass, sent = 0;
00A138  EB0000     CLR W0
00A13A  780F00     MOV W0, [W14]
419:               	uint8_t *p8 = (uint8_t*)data;
00A13C  9000BE     MOV [W14+6], W1
00A13E  980711     MOV W1, [W14+2]
420:               
421:               	while(length > 0) {
00A140  37000F     BRA 0xA160
00A160  90004E     MOV [W14+8], W0
00A162  E00000     CP0 W0
00A164  3AFFEE     BRA NZ, 0xA142
422:               		pass = BlockWriteUART1(p8, length);
00A142  90004E     MOV [W14+8], W0
00A144  780080     MOV W0, W1
00A146  90001E     MOV [W14+2], W0
00A148  07FFBD     RCALL BlockWriteUART1
00A14A  980720     MOV W0, [W14+4]
423:               		length -= pass;
00A14C  90002E     MOV [W14+4], W0
00A14E  9000CE     MOV [W14+8], W1
00A150  508000     SUB W1, W0, W0
00A152  980740     MOV W0, [W14+8]
424:               		sent += pass;
00A154  90002E     MOV [W14+4], W0
00A156  400F1E     ADD W0, [W14], [W14]
425:               		p8 += pass;
00A158  90002E     MOV [W14+4], W0
00A15A  90009E     MOV [W14+2], W1
00A15C  408000     ADD W1, W0, W0
00A15E  980710     MOV W0, [W14+2]
426:               	}
427:               	return sent;
00A166  78001E     MOV [W14], W0
428:               }
00A168  FA8000     ULNK
00A16A  060000     RETURN
