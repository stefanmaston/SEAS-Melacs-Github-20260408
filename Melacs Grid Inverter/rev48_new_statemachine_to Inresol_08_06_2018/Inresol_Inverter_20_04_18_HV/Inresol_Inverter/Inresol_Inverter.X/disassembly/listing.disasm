661:               // TX Response - Get Recording Data - ASCIIHEX & BIN Structures
662:               typedef struct __attribute__((packed)) TxRspGetRecData_ASCIIHEX_s {
663:               	char		Start_of_Frame;
664:               	char		Rsp_Code[2];
665:               	char		Addr[8];
666:               	char		Data[APP_DATAREC_PACKET_LENGTH][2];
667:               	char		Frame_Counter[2];
668:               	char		End_of_Frame;
669:               } TxRspGetRecData_ASCIIHEX_t;
670:               
671:               typedef struct __attribute__((packed)) TxRspGetRecData_BIN_s {
672:               	uint32_t	Addr;
673:               	uint8_t		Data[APP_DATAREC_PACKET_LENGTH];
674:               } TxRspGetRecData_BIN_t;
675:               
676:               //#define TX_RSP_GET_REC_DATA_TYPE		DATA_8BYTES, DATA_2BYTES, DATA_2BYTES, DATA_2BYTES, DATA_2BYTES, DATA_2BYTES, DATA_2BYTES, DATA_2BYTES, DATA_2BYTES, DATA_NULL
677:               #define TX_RSP_GET_REC_DATA_TYPE		DATA_8BYTES, REP_DIG(0,1,2,DATA_2BYTES), DATA_NULL
678:               
679:               /* TX Response - Get SM Data - Frame Description
680:               Byte  0 - 'R' ASCII character (Start of Frame Rsp)
681:               Bytes 1, 2 - ASCII HEX representation of uint8_t value - the Response Code (e.g. 00 means: RSP_ACK)
682:               Bytes 3, 4 - ASCII HEX representation of uint8_t value - the SM State
683:               Bytes 5, 6 - ASCII HEX representation of uint8_t value - the SM Error
684:               Bytes 7, 8, 9, 10 - ASCII HEX representation of uint16_t value - the TimeStamp
685:               Bytes 11, 12, 13, 14, 15, 16, 17, 18 - ASCII HEX representation of uint32_t value - the TimeStamp
686:               Bytes 19, 20 - ASCII HEX representation of uint8_t value - the Incremented Frame Counter
687:               Byte 21 - 'Z' ASCII character (End of Frame)
688:               Byte 22 - <CR> control character (Carriage Return)
689:               Byte 23 - <LF> control character (Line Feed)
690:               */
691:               
692:               // TX Response - Get Recording Data - ASCIIHEX & BIN Structures
693:               typedef struct __attribute__((packed)) TxRspGetSMData_ASCIIHEX_s {
694:               	char		Start_of_Frame;
695:               	char		Rsp_Code[2];
696:               	char		State[2];
697:               	char		Error[2];
698:               	char		TimeStamp_ms[4];
699:               	char		TimeStamp_s[8];
700:               	char		Frame_Counter[2];
701:               	char		End_of_Frame;
702:               } TxRspGetSMData_ASCIIHEX_t;
703:               
704:               typedef struct __attribute__((packed)) TxRspGetSMData_BIN_s {
705:               	uint8_t		State;
706:               	uint8_t		Error;
707:               	uint16_t	TimeStamp_ms;
708:               	uint32_t	TimeStamp_s;
709:               } TxRspGetSMData_BIN_t;
710:               
711:               #define TX_RSP_GET_SM_DATA_TYPE		DATA_2BYTES, DATA_2BYTES, DATA_4BYTES, DATA_8BYTES, DATA_NULL
712:               /////
