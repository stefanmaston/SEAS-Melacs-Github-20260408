78:                typedef void (*rx_cmd_cb_t)(void *data);
79:                typedef void (*tx_rsp_cb_t)(void *data);
80:                
81:                typedef struct RxCmdList_s {
82:                	uint8_t cmd_code;
83:                	uint8_t cmd_length;
84:                	uint8_t *param_types;
85:                	rx_cmd_cb_t cmd_cb;
86:                } RxCmdList_t;
87:                
88:                typedef struct TxRspList_s {
89:                	uint8_t rsp_code;
90:                	uint8_t *param_types;
91:                	tx_rsp_cb_t rsp_cb;
92:                } TxRspList_t;
93:                
94:                // Note: The MSBs of all values in frames are transmitted at the first position.
95:                
96:                /* RX Command - Set Response - Frame Description
97:                Byte  0 - 'S' ASCII character (Start of Frame Cmd)
98:                Bytes 1, 2 - ASCII HEX representation of uint8_t value - the Command Code (e.g. 00 means: SET_RESPONSE)
99:                Bytes 3, 4 - ASCII HEX representation of uint8_t value - the Response Type (e.g. 00 means: RSP_OFF, 01 means: RSP_FW_VER etc...)
100:               Bytes 5, 6 - ASCII HEX representation of uint8_t value - the Incremented Frame Counter
101:               Byte 7 - 'Z' ASCII character (End of Frame)
102:               Byte 8 - <CR> control character (Carriage Return)
103:               Byte 9 - <LF> control character (Line Feed)
104:               */
105:               
106:               // RX Command - Set Response Type - ASCIIHEX & BIN Structures
107:               typedef struct __attribute__((packed)) RxCmdSetResponse_ASCIIHEX_s {
108:               	char		Start_of_Frame;
109:               	char		Cmd_Code[2];
110:               	char		Response_Type[2];
111:               	char		Frame_Counter[2];
112:               	char		End_of_Frame;
113:               } RxCmdSetResponse_ASCIIHEX_t;
114:               
115:               typedef struct __attribute__((packed)) RxCmdSetResponse_BIN_s {
116:               	uint8_t		Response_Type;
117:               	uint8_t		Frame_Counter;
118:               } RxCmdSetResponse_BIN_t;
119:               
120:               #define RX_CMD_SET_RESPONSE_TYPE		DATA_2BYTES, DATA_2BYTES, DATA_NULL
121:               #define RX_CMD_SET_RESPONSE_SIZE		sizeof(RxCmdSetResponse_ASCIIHEX_t)
122:               
123:               /* RX Command - Set Echo On/Off - Frame Description
124:               Byte  0 - 'S' ASCII character (Start of Frame Cmd)
125:               Bytes 1, 2 - ASCII HEX representation of uint8_t value - the Command Code (e.g. 01 means: SET_ECHO_ON_OFF)
126:               Bytes 3, 4 - ASCII HEX representation of uint8_t value - the Echo On/Off state (e.g. 00 means: ECHO_OFF, 01 means: ECHO_ON)
127:               Bytes 5, 6 - ASCII HEX representation of uint8_t value - the Incremented Frame Counter
128:               Byte 7 - 'Z' ASCII character (End of Frame)
129:               Byte 8 - <CR> control character (Carriage Return)
130:               Byte 9 - <LF> control character (Line Feed)
131:               */
132:               
133:               // RX Command - Set Echo On/Off - ASCIIHEX & BIN Structures
134:               typedef struct __attribute__((packed)) RxCmdSetEchoOnOff_ASCIIHEX_s {
135:               	char		Start_of_Frame;
136:               	char		Cmd_Code[2];
137:               	char		Echo_State[2];
138:               	char		Frame_Counter[2];
139:               	char		End_of_Frame;
140:               } RxCmdSetEchoOnOff_ASCIIHEX_t;
141:               
142:               typedef struct __attribute__((packed)) RxCmdSetEchoOnOff_BIN_s {
143:               	uint8_t		Echo_State;
144:               	uint8_t		Frame_Counter;
145:               } RxCmdSetEchoOnOff_BIN_t;
146:               
147:               #define RX_CMD_SET_ECHO_ON_OFF_TYPE		DATA_2BYTES, DATA_2BYTES, DATA_NULL
148:               #define RX_CMD_SET_ECHO_ON_OFF_SIZE		sizeof(RxCmdSetEchoOnOff_ASCIIHEX_t)
149:               
150:               /* RX Command - Set DDS Parameters - Frame Description
151:               Byte  0 - 'S' ASCII character (Start of Frame Cmd)
152:               Bytes 1, 2 - ASCII HEX representation of uint8_t value - the Command Code (e.g. 02 means: SET_DDS_PARAMS)
153:               Bytes 3, 4, 5, 6 - ASCII HEX representation of uint16_t value - the Frequency in 0.1Hz (e.g. 01F4 means: 50.0 Hz)
154:               Bytes 7, 8, 9, 10 - ASCII HEX representation of int16_t value - the Phase 2 Shift from -360deg to +360deg (-2Pi to +2Pi) (e.g. 2AAA means: +120deg)
155:               Bytes 11, 12, 13, 14 - ASCII HEX representation of int16_t value - the Phase 3 Shift from -360deg to +360deg (-2Pi to +2Pi) (e.g. 5555 means: +240deg)
156:               Bytes 15, 16, 17, 18 - ASCII HEX representation of uint16_t value - the Phase 1 Amplitude from 0 to 65535, 0% - 100% (e.g. 7FFF means: 50%)
157:               Bytes 19, 20, 21, 22 - ASCII HEX representation of uint16_t value - the Phase 2 Amplitude from 0 to 65535, 0% - 100% (e.g. BFFF means: 75%)
158:               Bytes 23, 24, 25, 26 - ASCII HEX representation of uint16_t value - the Phase 3 Amplitude from 0 to 65535, 0% - 100% (e.g. FFFF means: 100%)
159:               Bytes 27, 28 - ASCII HEX representation of uint8_t value - the Incremented Frame Counter
160:               Byte 29 - 'Z' ASCII character (End of Frame)
161:               Byte 30 - <CR> control character (Carriage Return)
162:               Byte 31 - <LF> control character (Line Feed)
163:               */
164:               
165:               // RX Command - Set DDS Parameters - ASCIIHEX & BIN Structures
166:               typedef struct __attribute__((packed)) RxCmdSetDdsParams_ASCIIHEX_s {
167:               	char		Start_of_Frame;
168:               	char		Cmd_Code[2];
169:               	char		Freq[4];
170:               	char		Phase2_Shift[4];
171:               	char		Phase3_Shift[4];
172:               	char		Phase1_Amplitude[4];
173:               	char		Phase2_Amplitude[4];
174:               	char		Phase3_Amplitude[4];
175:               	char		Frame_Counter[2];
176:               	char		End_of_Frame;
177:               } RxCmdSetDdsParams_ASCIIHEX_t;
178:               
179:               typedef struct __attribute__((packed)) RxCmdSetDdsParams_BIN_s {
180:               	uint16_t	Freq;
181:               	int16_t		Phase2_Shift;
182:               	int16_t		Phase3_Shift;
183:               	uint16_t	Phase1_Amplitude;
184:               	uint16_t	Phase2_Amplitude;
185:               	uint16_t	Phase3_Amplitude;
186:               	uint8_t		Frame_Counter;
187:               } RxCmdSetDdsParams_BIN_t;
188:               
189:               #define RX_CMD_SET_DDS_PARAMS_TYPE		DATA_4BYTES, DATA_4BYTES, DATA_4BYTES, DATA_4BYTES, DATA_4BYTES, DATA_4BYTES, DATA_2BYTES, DATA_NULL
190:               #define RX_CMD_SET_DDS_PARAMS_SIZE		sizeof(RxCmdSetDdsParams_ASCIIHEX_t)
191:               
192:               /* RX Command - Set Relays - Frame Description
193:               Byte  0 - 'S' ASCII character (Start of Frame Cmd)
194:               Bytes 1, 2 - ASCII HEX representation of uint8_t value - the Command Code (e.g. 03 means: SET_RELAYS)
195:               Bytes 3, 4 - ASCII HEX representation of uint8_t value - the Relays State (e.g. 00 means: All_OFF, 01 means: FIRST_ON etc...)
196:               Bytes 5, 6 - ASCII HEX representation of uint8_t value - the Incremented Frame Counter
197:               Byte 7 - 'Z' ASCII character (End of Frame)
198:               Byte 8 - <CR> control character (Carriage Return)
199:               Byte 9 - <LF> control character (Line Feed)
200:               */
201:               
202:               // RX Command - Set Relays Type - ASCIIHEX & BIN Structures
203:               typedef struct __attribute__((packed)) RxCmdSetRelays_ASCIIHEX_s {
204:               	char		Start_of_Frame;
205:               	char		Cmd_Code[2];
206:               	char		Relays_State[2];
207:               	char		Frame_Counter[2];
208:               	char		End_of_Frame;
209:               } RxCmdSetRelays_ASCIIHEX_t;
210:               
211:               typedef struct __attribute__((packed)) RxCmdSetRelays_BIN_s {
212:               	uint8_t		Relays_State;
213:               	uint8_t		Frame_Counter;
214:               } RxCmdSetRelays_BIN_t;
215:               
216:               #define RX_CMD_SET_RELAYS_TYPE			DATA_2BYTES, DATA_2BYTES, DATA_NULL
217:               #define RX_CMD_SET_RELAYS_SIZE			sizeof(RxCmdSetRelays_ASCIIHEX_t)
218:               
219:               /* RX Command - Set I Trip Parameters - Frame Description
220:               Byte  0 - 'S' ASCII character (Start of Frame Cmd)
221:               Bytes 1, 2 - ASCII HEX representation of uint8_t value - the Command Code (e.g. 04 means: SET_ITRIP_PARAMS)
222:               Bytes 3, 4, 5, 6 - ASCII HEX representation of uint16_t value - the I Trip  Inv Amplitude from 0 to 65535, 0% - 100% (e.g. 7FFF means: 50%)
223:               Bytes 7, 8, 9, 10 - ASCII HEX representation of int16_t value - the I Trip Grid Amplitude from 0 to 65535, 0% - 100% (e.g. FFFF means: 100%)
224:               Bytes 11, 12 - ASCII HEX representation of uint8_t value - the Incremented Frame Counter
225:               Byte 13 - 'Z' ASCII character (End of Frame)
226:               Byte 14 - <CR> control character (Carriage Return)
227:               Byte 15 - <LF> control character (Line Feed)
228:               */
229:               
230:               // RX Command - Set I Trip Parameters - ASCIIHEX & BIN Structures
