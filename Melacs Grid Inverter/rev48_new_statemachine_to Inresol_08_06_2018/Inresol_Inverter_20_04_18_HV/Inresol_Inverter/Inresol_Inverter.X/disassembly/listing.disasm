268:               ******************************************************************************/
269:               unsigned int getsUART1(unsigned int length,unsigned int *buffer,
270:                                      unsigned int uart_data_wait)
271:               {
272:                   int wait = 0;
273:                   char *temp_ptr = (char *) buffer;
274:               
275:                   while(length)                         /* read till length is 0 */
276:                   {
277:                       while(!DataRdyUART1())
278:                       {
279:                           if(wait < uart_data_wait)
280:                               wait++ ;                  /*wait for more data */
281:                           else
282:                               return(length);           /*Time out- Return words/bytes to be read */
283:                       }
284:                       wait=0;
285:                       if(U1MODEbits.PDSEL == 3)         /* check if TX/RX is 8bits or 9bits */
286:                           *buffer++ = U1RXREG;          /* data word from HW buffer to SW buffer */
287:               	else
288:                           *temp_ptr++ = U1RXREG & 0xFF; /* data byte from HW buffer to SW buffer */
289:               
290:                       length--;
291:                   }
292:               
293:                   return(length);                       /* number of data yet to be received i.e.,0 */
294:               }
295:               
296:               /***************************************************************************
297:               * Function Name     : putsUART1                                            *
298:               * Description       : This function puts the data string to be transmitted *
299:               *                     into the transmit buffer (till NULL character)       *
300:               * Parameters        : unsigned int * address of the string buffer to be    *  
301:               *                     transmitted                                          *
302:               * Return Value      : None                                                 *
303:               ***************************************************************************/
304:               void putsUART1(unsigned int *buffer)
305:               {
306:                   char * temp_ptr = (char *) buffer;
307:               
308:                   /* transmit till NULL character is encountered */
309:               
310:                   if(U1MODEbits.PDSEL == 3)        /* check if TX is 8bits or 9bits */
311:                   {
312:                       while(*buffer != '\0') 
313:                       {
314:                           while(U1STAbits.UTXBF); /* wait if the buffer is full */
315:                           U1TXREG = *buffer++;    /* transfer data word to TX reg */
316:                       }
317:                   }
318:                   else
319:                   {
320:                       while(*temp_ptr != '\0')
321:                       {
322:                           while(U1STAbits.UTXBF);  /* wait if the buffer is full */
323:                           U1TXREG = *temp_ptr++;   /* transfer data byte to TX reg */
324:                       }
325:                   }
326:               }
327:               
328:               /***************************************************************************
329:               * Function Name     : ReadUART1                                            *
330:               * Description       : This function returns the contents of UxRXREG buffer * 
331:               * Parameters        : None                                                 *
332:               * Return Value      : unsigned int value from UxRXREG receive buffer       *
333:               ***************************************************************************/
334:               unsigned int ReadUART1(void)
335:               {
336:                   if(U1MODEbits.PDSEL == 3)
337:                       return (U1RXREG);
338:                   else
339:                       return (U1RXREG & 0xFF);
340:               }
341:               
342:               /*********************************************************************
343:               * Function Name     : WriteUART1                                     *
344:               * Description       : This function writes data into the UxTXREG,    *
345:               * Parameters        : unsigned int data the data to be written       *
346:               * Return Value      : None                                           *
347:               *********************************************************************/
348:               void WriteUART1(unsigned int data)
349:               {
350:                   if(U1MODEbits.PDSEL == 3)
351:                       U1TXREG = data;
352:                   else
353:                       U1TXREG = data & 0xFF;
354:               }
355:               #endif
356:               
357:               void WriteUART1(unsigned char data)
358:               {
00A0A2  FA0002     LNK #0x2
00A0A4  784F00     MOV.B W0, [W14]
359:               	U1TXREG = data;
00A0A6  FB801E     ZE [W14], W0
00A0A8  881120     MOV W0, U1TXREG
360:               }
00A0AA  FA8000     ULNK
00A0AC  060000     RETURN
361:               
362:               unsigned char ReadUART1(void)
363:               {
00A0AE  FA0000     LNK #0x0
364:               	return (U1RXREG);
00A0B0  801130     MOV U1RXREG, W0
00A0B2  784000     MOV.B W0, W0
365:               }
00A0B4  FA8000     ULNK
00A0B6  060000     RETURN
366:               
367:               char DataRdyUART1(void)
368:               {
00A0B8  FA0000     LNK #0x0
369:               	return(U1STAbits.URXDA);
00A0BA  801110     MOV U1STA, W0
00A0BC  784000     MOV.B W0, W0
00A0BE  604061     AND.B W0, #0x1, W0
370:               }
00A0C0  FA8000     ULNK
00A0C2  060000     RETURN
371:               
372:               // Transmit a byte array through the UART peripheral (non-blocking)
373:               int BlockWriteUART1(const void *data, int numBytes)
374:               {
00A0C4  FA0008     LNK #0x8
00A0C6  980720     MOV W0, [W14+4]
00A0C8  980731     MOV W1, [W14+6]
375:               	int sent = 0;
00A0CA  EB0000     CLR W0
00A0CC  780F00     MOV W0, [W14]
376:               	uint8_t *p8 = (uint8_t*)data;
00A0CE  9000AE     MOV [W14+4], W1
00A0D0  980711     MOV W1, [W14+2]
377:               
378:               	// Send until the transmit FIFO is full or out of bytes
379:               	while((sent < numBytes) && (U1STAbits.UTXBF == 0)) {
00A0D2  370007     BRA 0xA0E2
00A0E2  90003E     MOV [W14+6], W0
00A0E4  78009E     MOV [W14], W1
00A0E6  508F80     SUB W1, W0, [W15]
00A0E8  3D0005     BRA GE, 0xA0F4
00A0EA  801111     MOV U1STA, W1
00A0EC  202000     MOV #0x200, W0
00A0EE  608000     AND W1, W0, W0
00A0F0  E00000     CP0 W0
00A0F2  32FFF0     BRA Z, 0xA0D4
380:               		WriteUART1(*p8);
00A0D4  90001E     MOV [W14+2], W0
00A0D6  784010     MOV.B [W0], W0
00A0D8  07FFE4     RCALL WriteUART1
381:               		p8++;
00A0DA  90001E     MOV [W14+2], W0
00A0DC  E80000     INC W0, W0
00A0DE  980710     MOV W0, [W14+2]
382:               		sent++;
00A0E0  E80F1E     INC [W14], [W14]
383:               	}
384:               	return sent;
00A0F4  78001E     MOV [W14], W0
385:               }
00A0F6  FA8000     ULNK
00A0F8  060000     RETURN
386:               
387:               #if (BSP_UART_1_RX_RB_SIZE != 0)
388:               // UART receive-only interrupt handler for ring buffers
389:               static void BSP_UART_1_Rx_IntHandlerRB(void)
390:               {
00A0FA  FA0002     LNK #0x2
391:               	// Read the receive buffer until at least one or more character can be read
392:               	// New data will be ignored if data not popped in time
393:               	while(DataRdyUART1()) {
00A0FC  370005     BRA 0xA108
00A108  07FFD7     RCALL DataRdyUART1
00A10A  E00400     CP0.B W0
00A10C  3AFFF8     BRA NZ, 0xA0FE
394:               		uint8_t ch = ReadUART1();
00A0FE  07FFD7     RCALL ReadUART1
00A100  784F00     MOV.B W0, [W14]
395:               		RingBuffer_Insert(&Uart_1_Rx_Ring, &ch);
00A102  78008E     MOV W14, W1
00A104  2296A0     MOV #0x296A, W0
00A106  070BDB     RCALL RingBuffer_Insert
396:               	}
397:               }
00A10E  FA8000     ULNK
00A110  060000     RETURN
398:               #endif
399:               
400:               #if (BSP_UART_1_TX_RB_SIZE != 0)
401:               // UART transmit-only interrupt handler for ring buffers
402:               static void BSP_UART_1_Tx_IntHandlerRB(void)
403:               {
00A112  FA0002     LNK #0x2
404:               	uint8_t ch;
405:               
406:               	// Fill FIFO until full or until TX ring buffer is empty
407:               	while((U1STAbits.UTXBF == 0) && RingBuffer_Pop(&Uart_1_Tx_Ring, &ch)) {
00A114  370002     BRA 0xA11A
00A11A  801111     MOV U1STA, W1
00A11C  202000     MOV #0x200, W0
00A11E  608000     AND W1, W0, W0
00A120  E00000     CP0 W0
00A122  3A0005     BRA NZ, 0xA12E
00A124  78008E     MOV W14, W1
00A126  228E00     MOV #0x28E0, W0
00A128  070C6E     RCALL RingBuffer_Pop
00A12A  E00000     CP0 W0
00A12C  3AFFF4     BRA NZ, 0xA116
408:               		WriteUART1(ch);
00A116  78401E     MOV.B [W14], W0
00A118  07FFC4     RCALL WriteUART1
409:               	}
410:               }
00A12E  FA8000     ULNK
00A130  060000     RETURN
411:               #endif
