13:                #ifndef UINT16_MAX
14:                #define UINT16_MAX (65535U)
15:                #endif
16:                
17:                #define APP_OCP_OC_PWM_OFFSET_25PERCENT			((((uint32_t)UINT16_MAX + 1) >> 2) * 1)		// 25% of 65536
18:                #define APP_OCP_OC_PWM_OFFSET_75PERCENT			((((uint32_t)UINT16_MAX + 1) >> 2) * 3)		// 75% of 65536
19:                
20:                volatile uint16_t	App_OCP_ITrip_Inv;			// I-Trip Magnitude for channel Inv or Upper
21:                volatile uint16_t	App_OCP_ITrip_Grid;			// I-Trip Magnitude for channel Grid or Lower
22:                volatile uint8_t	App_OCP_OC_Status;
23:                
24:                #if (defined HARDWARE_VERSION_1)
25:                // Note: The Over Current Protection element parameters are:
26:                // P/N: ACS716KLATR-25CB-NL (Ip=+/-25A; Sens=18.5mV/A; No Latched Fault; Voc range=0.25Vcc<->0.4Vcc)
27:                // Ioc Min:  0.25 * 3300mV / 18.5 =  825mV / 18.5 = 44.6A
28:                // Ioc Max:  0.40 * 3300mV / 18.5 = 1320mV / 18.5 = 71.4A
29:                // Ioc Max HW Limited: 3300mV / 3 = 1100mV / 18.5 = 59.5A
30:                
31:                // Example: VOC = Sens × Ioc = 18.5 × 50A = 925mV
32:                
33:                // PWM Max: 1100mV = 1.00
34:                // PWM Min: 825mV / 1100mV = 0.75
35:                
36:                inline uint16_t App_OCP_Get_Sample_Scaled_Ch1(void)
37:                {
00CAD0  FA0002     LNK #0x2
38:                	uint16_t	sample_value;
39:                
40:                	sample_value = APP_OCP_OC_PWM_OFFSET_75PERCENT + (App_OCP_ITrip_Inv >> 2);		// 0.75 <-> 1.0
00CAD2  8097A0     MOV App_OCP_ITrip_Inv, W0
00CAD4  DE00C2     LSR W0, #2, W1
00CAD6  2C0000     MOV #0xC000, W0
00CAD8  408F00     ADD W1, W0, [W14]
41:                	return sample_value;
00CADA  78001E     MOV [W14], W0
42:                }
00CADC  FA8000     ULNK
00CADE  060000     RETURN
43:                
