00A184  07FFC6     RCALL _BSP_UART_1_Tx_IntHandlerRB
445:               
446:               	/* Add additional data to transmit ring buffer if possible */
447:               	ret += RingBuffer_InsertMult(&Uart_1_Tx_Ring, (p8 + ret), (length - ret));
00A186  9000BE     MOV [W14+6], W1
00A188  90001E     MOV [W14+2], W0
00A18A  508000     SUB W1, W0, W0
00A18C  780080     MOV W0, W1
00A18E  90001E     MOV [W14+2], W0
00A190  40001E     ADD W0, [W14], W0
00A192  780101     MOV W1, W2
00A194  780080     MOV W0, W1
00A196  228E00     MOV #0x28E0, W0
00A198  070BB6     RCALL RingBuffer_InsertMult
00A19A  90009E     MOV [W14+2], W1
00A19C  408000     ADD W1, W0, W0
00A19E  980710     MOV W0, [W14+2]
448:               
449:               	// Enable UART transmit interrupt
450:               	BSP_UART_1_Tx_Interrupt_Enable();
00A1A0  07FF51     RCALL BSP_UART_1_Tx_Interrupt_Enable
451:               
452:               	return ret;
00A1A2  90001E     MOV [W14+2], W0
453:               }
00A1A4  FA8000     ULNK
00A1A6  060000     RETURN
