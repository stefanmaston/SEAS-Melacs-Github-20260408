                                                  7:     ; 
                                                  8:     ; You should refer to the license agreement accompanying this Software for
                                                  9:     ; additional information regarding your rights and obligations.
                                                  10:    ; 
                                                  11:    ; SOFTWARE AND DOCUMENTATION ARE PROVIDED "AS IS" WITHOUT WARRANTY OF ANY KIND,
                                                  12:    ; EITHER EXPRESS OR IMPLIED, INCLUDING WITHOUT LIMITATION, ANY WARRANTY OF
                                                  13:    ; MERCHANTABILITY, TITLE, NON-INFRINGEMENT AND FITNESS FOR A PARTICULAR PURPOSE.
                                                  14:    ; IN NO EVENT SHALL MICROCHIP OR ITS LICENSORS BE LIABLE OR OBLIGATED UNDER
                                                  15:    ; CONTRACT, NEGLIGENCE, STRICT LIABILITY, CONTRIBUTION, BREACH OF WARRANTY, OR
                                                  16:    ; OTHER LEGAL EQUITABLE THEORY ANY DIRECT OR INDIRECT DAMAGES OR EXPENSES
                                                  17:    ; INCLUDING BUT NOT LIMITED TO ANY INCIDENTAL, SPECIAL, INDIRECT, PUNITIVE OR
                                                  18:    ; CONSEQUENTIAL DAMAGES, LOST PROFITS OR LOST DATA, COST OF PROCUREMENT OF
                                                  19:    ; SUBSTITUTE GOODS, TECHNOLOGY, SERVICES, OR ANY CLAIMS BY THIRD PARTIES
                                                  20:    ; (INCLUDING BUT NOT LIMITED TO ANY DEFENSE THEREOF), OR OTHER SIMILAR COSTS.
                                                  21:    ;*********************************************************************************
                                                  22:    
                                                  23:              .include "mc_interfaces_dspic.inc"
                                                  24:    ; Inputs:
                                                  25:    ;  ALPHABETA.alpha
                                                  26:    ;  ALPHABETA.beta
                                                  27:    
                                                  28:    ; Outputs:
                                                  29:    ;  ABC.a
                                                  30:    ;  ABC.b
                                                  31:    ;  ABC.c		  
                                                  32:    		  
                                                  33:    ; Register usage
                                                  34:              .equ workW0,  w0  ; working register
                                                  35:    		  .equ workW1,  w1  ; working register
                                                  36:    
                                                  37:              .equ workW2,  w2  ; working register
                                                  38:              .equ CorconW4,w4  ; CORCON temp
                                                  39:              .equ alphaW4, w4  ; alpha
                                                  40:              .equ betaW5,  w5  ; beta
                                                  41:              .equ Sq3Ov2W6,w6  ; sqrt(3)/2
                                                  42:    
                                                  43:    ; Constants
                                                  44:              .equ Sq3OV2,0x6ED9 ; sqrt(3)/2 in 1.15 format
                                                  45:    
                                                  46:    ; Note
                                                  47:    ;  This function requires CORCON register to be setup in a certain state
                                                  48:    ;  in order to operate correctly. Due to this requirement, this function
                                                  49:    ;  will save the CORCON register on the stack in the beginning of the
                                                  50:    ;  function and restore it before the function return.
                                                  51:    ;  After saving the CORCON register, this function writes to all bits of
                                                  52:    ;  the CORCON register. Thus, for the brief duration when this function is
                                                  53:    ;  executing, the state of CORCON register may be different from its state
                                                  54:    ;  as set by the function caller. This may change the CPU core behavior with
                                                  55:    ;  respect to exception processing latency, DO loop termination, CPU interrupt
                                                  56:    ;  priority level and DSP-engine behavior.
                                                  57:    
                                                  58:    ;=================== CODE =====================
                                                  59:    
                                                  60:              .section  .text
                                                  61:              .global   _MC_TransformClarkeInverseSwappedInput_Assembly
                                                  62:              .global   MC_TransformClarkeInverseSwappedInput_Assembly
                                                  63:    
                                                  64:    _MC_TransformClarkeInverseSwappedInput_Assembly:
                                                  65:    MC_TransformClarkeInverseSwappedInput_Assembly:
                                                  66:         ;; Save CORCON, then configure as needed
00DCF0  F80044     PUSH CORCON                    67:              push      CORCON
00DCF2  200E24     MOV #0xE2, W4                  68:              mov.w     #0x00E2,CorconW4
00DCF4  880224     MOV W4, CORCON                 69:              mov.w     CorconW4,CORCON
                                                  70:         ;; workW0 : ALPHABETA*
                                                  71:         ;; workW1 : ABC*
                                                  72:    
                                                  73:         ;; Get alpha, beta from ALPHABETA structure
00DCF6  900200     MOV [W0+0], W4                 74:              mov.w     [workW0+ALPHABETA_alpha],alphaW4
00DCF8  900290     MOV [W0+2], W5                 75:              mov.w     [workW0+ALPHABETA_beta],betaW5
                                                  76:    
                                                  77:         ;; a = beta
00DCFA  980085     MOV W5, [W1+0]                 78:              mov.w     betaW5,[workW1+ABC_a]
                                                  79:    
                                                  80:         ;; Load Sq(3)/2
00DCFC  26ED96     MOV #0x6ED9, W6                81:              mov.w     #Sq3OV2,Sq3Ov2W6
                                                  82:    
                                                  83:         ;; AccA = -beta/2
00DCFE  CA0085     LAC W5, #1, A                  84:              lac       betaW5,#1,A
00DD00  CB1000     NEG A                          85:              neg       A
                                                  86:    
                                                  87:         ;; b = -beta/2 + (sqrt(3)/2) * alpha
00DD02  C10112     MAC W4*W6, A                   88:              mac       alphaW4*Sq3Ov2W6,A           ;add alpha*sqrt(3)/2 to A
00DD04  CC0002     SAC A, W2                      89:              sac       A,workW2
00DD06  980092     MOV W2, [W1+2]                 90:              mov.w     workW2,[workW1+ABC_b]
                                                  91:    
                                                  92:         ;; AccA = -beta/2
00DD08  CA0085     LAC W5, #1, A                  93:              lac       betaW5,#1,A
00DD0A  CB1000     NEG A                          94:              neg       A
                                                  95:    
                                                  96:         ;; c = -beta/2 - (sqrt(3)/2) * alpha
00DD0C  C14112     MSC W4*W6, A                   97:              msc       alphaW4*Sq3Ov2W6,A            ;sub alpha*sqrt(3)/2 from A
00DD0E  CC0002     SAC A, W2                      98:              sac       A,workW2
00DD10  9800A2     MOV W2, [W1+4]                 99:              mov.w     workW2,[workW1+ABC_c]
                                                  100:   		  
                                                  101:   	 ;; Return 1	  
00DD12  200010     MOV #0x1, W0                   102:   		  mov.w     #1, workW0
00DD14  F90044     POP CORCON                     103:             pop       CORCON
00DD16  060000     RETURN                         104:             return
                                                  105:             .end
---  C:/Projects/Microchip/Workspace/Inresol_Inverter/lib_src/mc_filter.s  ------------------------------
                                                  1:     ;*********************************************************************************
                                                  2:     ; Copyright (c) 2013 released Microchip Technology Inc.  All rights reserved.
                                                  3:     ; Microchip licenses to you the right to use, modify, copy and distribute
                                                  4:     ; Software only when embedded on a Microchip microcontroller or digital signal
                                                  5:     ; controller that is integrated into your product or third party product
                                                  6:     ; (pursuant to the sublicense terms in the accompanying license agreement).
                                                  7:     ; 
                                                  8:     ; You should refer to the license agreement accompanying this Software for
                                                  9:     ; additional information regarding your rights and obligations.
                                                  10:    ; 
                                                  11:    ; SOFTWARE AND DOCUMENTATION ARE PROVIDED "AS IS" WITHOUT WARRANTY OF ANY KIND,
                                                  12:    ; EITHER EXPRESS OR IMPLIED, INCLUDING WITHOUT LIMITATION, ANY WARRANTY OF
                                                  13:    ; MERCHANTABILITY, TITLE, NON-INFRINGEMENT AND FITNESS FOR A PARTICULAR PURPOSE.
                                                  14:    ; IN NO EVENT SHALL MICROCHIP OR ITS LICENSORS BE LIABLE OR OBLIGATED UNDER
                                                  15:    ; CONTRACT, NEGLIGENCE, STRICT LIABILITY, CONTRIBUTION, BREACH OF WARRANTY, OR
                                                  16:    ; OTHER LEGAL EQUITABLE THEORY ANY DIRECT OR INDIRECT DAMAGES OR EXPENSES
                                                  17:    ; INCLUDING BUT NOT LIMITED TO ANY INCIDENTAL, SPECIAL, INDIRECT, PUNITIVE OR
                                                  18:    ; CONSEQUENTIAL DAMAGES, LOST PROFITS OR LOST DATA, COST OF PROCUREMENT OF
                                                  19:    ; SUBSTITUTE GOODS, TECHNOLOGY, SERVICES, OR ANY CLAIMS BY THIRD PARTIES
                                                  20:    ; (INCLUDING BUT NOT LIMITED TO ANY DEFENSE THEREOF), OR OTHER SIMILAR COSTS.
                                                  21:    ;*********************************************************************************
                                                  22:    
                                                  23:             .include "mc_interfaces_dspic.inc"
                                                  24:    ; Inputs:
                                                  25:    ;  PIPARMIN kp,ki,kc,out_Max,out_Min,in_Ref,in_Meas
                                                  26:    
                                                  27:    ; Outputs:
                                                  28:    ;  PIPARMOUT out
                                                  29:    
                                                  30:    ; Register usage
                                                  31:    
                                                  32:              .equ workW0,   w0  ; Working register
                                                  33:              .equ workW1,   w1  ; Working register (function I/O only, don't reuse)
                                                  34:              .equ workW2,   w2  ; Working register (function I/O only, don't reuse)
                                                  35:              .equ workW3,   w3  ; Working register (function I/O only, don't reuse)
                                                  36:    		  
                                                  37:              .equ StateptrW1,   w1   ; PI state pointer
                                                  38:              .equ OutptrW2,     w2   ; Pointer to out
                                                  39:              .equ OutW3,        w3   ; Output
                                                  40:              .equ ErrW4,        w4   ; Error term: in_Ref-in_Meas
                                                  41:              .equ CorconW4,     w4   ; CORCON temp
                                                  42:              .equ workW5,       w5   ; Working register
                                                  43:              .equ UnlimitW6,    w6   ; U: unlimited output 
                                                  44:              .equ workW7,       w7   ; Working register
                                                  45:    
                                                  46:    ; Constants		  
                                                  47:    		  .equ NKo,4 ; PI scaling coeff
                                                  48:    
                                                  49:    ; Note
                                                  50:    ;  This function requires CORCON register to be setup in a certain state
                                                  51:    ;  in order to operate correctly. Due to this requirement, this function
                                                  52:    ;  will save the CORCON register on the stack in the beginning of the
                                                  53:    ;  function and restore it before the function return.
                                                  54:    ;  After saving the CORCON register, this function writes to all bits of
                                                  55:    ;  the CORCON register. Thus, for the brief duration when this function is
                                                  56:    ;  executing, the state of CORCON register may be different from its state
                                                  57:    ;  as set by the function caller. This may change the CPU core behavior with
                                                  58:    ;  respect to exception processing latency, DO loop termination, CPU interrupt
                                                  59:    ;  priority level and DSP-engine behavior.
                                                  60:    
                                                  61:    ;=================== CODE =====================
                                                  62:    
                                                  63:              .section  .text
                                                  64:              .global   _MC_FilterUpdate_Assembly
                                                  65:              .global   MC_FilterUpdate_Assembly
                                                  66:    
                                                  67:    _MC_FilterUpdate_Assembly:
                                                  68:    MC_FilterUpdate_Assembly:
                                                  69:         ;; Save CORCON, then configure as needed
00D9F6  F80044     PUSH CORCON                    70:              push      CORCON
00D9F8  200E24     MOV #0xE2, W4                  71:              mov.w     #0x00E2,CorconW4
00D9FA  880224     MOV W4, CORCON                 72:              mov.w     CorconW4,CORCON
                                                  73:         ;; workW0 : in_Ref
                                                  74:    	 ;; workW1 : in_Meas
                                                  75:    	 ;; workW2 : FILTERSTATE*
                                                  76:    	 ;; workW3 : FILTERPARAMOUT* out
                                                  77:    
                                                  78:         ;; Err  = in_Ref - in_Meas
00D9FC  CA0000     LAC W0, A                      79:              lac       workW0,#0,A
00D9FE  CA8001     LAC W1, B                      80:              lac       workW1,#0,B
00DA00  CB3000     SUB A                          81:              sub       A
00DA02  CC0004     SAC A, W4                      82:              sac       A,#0,ErrW4
                                                  83:    
00DA04  780082     MOV W2, W1                     84:              mov.w	    workW2,StateptrW1
00DA06  780103     MOV W3, W2                     85:    	  mov.w     workW3,OutptrW2   
                                                  86:              
                                                  87:         ;; U  = integrator + Kp * Err * 2^NKo
00DA08  900011     MOV [W1+2], W0                 88:              mov.w     [StateptrW1+PISTATE_integratorH],workW0
00DA0A  CA8000     LAC W0, B                      89:              lac       workW0,B                 ; AccB = integrator
00DA0C  900001     MOV [W1+0], W0                 90:              mov.w     [StateptrW1+PISTATE_integratorL],workW0
00DA0E  880140     MOV W0, ACCB                   91:              mov.w     workW0,ACCBL
                                                  92:    
00DA10  9002A1     MOV [W1+4], W5                 93:              mov.w     [StateptrW1+PISTATE_kp],workW5
00DA12  C00113     MPY W4*W5, A                   94:              mpy       ErrW4*workW5,A
00DA14  C8007C     SFTAC A, #-4                   95:              sftac     A,#-NKo                  ; AccA = Kp*Err*2^NKo     
00DA16  CB0000     ADD A                          96:              add       A                        ; Sum = Sum + Kp*Err*2^NKo
00DA18  CC0006     SAC A, W6                      97:              sac       A,UnlimitW6              ; store U before tests
                                                  98:    
                                                  99:         ;; if( U > Outmax )
                                                  100:        ;;     Out = Outmax
                                                  101:        ;; else if( U < Outmin )
                                                  102:        ;;     Out = Outmin
                                                  103:        ;; else        
                                                  104:        ;;     Out = U 
                                                  105:   
00DA1A  9001D1     MOV [W1+10], W3                106:             mov.w     [StateptrW1+PISTATE_out_Max],OutW3
00DA1C  E13003     CP W6, W3                      107:             cp        UnlimitW6,OutW3
00DA1E  3C0004     BRA GT, 0xDA28                 108:             bra       GT,jPI5             ; U > Outmax; OutW3 = Outmax
                                                  109:   
00DA20  9001E1     MOV [W1+12], W3                110:             mov.w     [StateptrW1+PISTATE_out_Min],OutW3
00DA22  E13003     CP W6, W3                      111:             cp        UnlimitW6,OutW3
00DA24  340001     BRA LE, 0xDA28                 112:             bra       LE,jPI5             ; U < Outmin; OutW3 = Outmin
                                                  113:   
00DA26  780186     MOV W6, W3                     114:             mov.w     UnlimitW6,OutW3     ; OutW3 = U
                                                  115:   jPI5:
00DA28  780903     MOV W3, [W2]                   116:             mov.w     OutW3,[OutptrW2]
                                                  117:   
                                                  118:        ;; Ki * Err
00DA2A  9002B1     MOV [W1+6], W5                 119:             mov.w     [StateptrW1+PISTATE_ki],workW5
00DA2C  C00113     MPY W4*W5, A                   120:             mpy       ErrW4*workW5,A              ; A = Ki * ErrW4
                                                  121:   
                                                  122:        ;; Exc = U - Out
00DA2E  530303     SUB W6, W3, W6                 123:             sub.w     UnlimitW6,OutW3,UnlimitW6   ; UnlimitW6 = UnlimitW6 - OutW3
                                                  124:   
                                                  125:        ;; Ki * Err - Kc * Exc 
00DA30  9002C1     MOV [W1+8], W5                 126:             mov.w     [StateptrW1+PISTATE_kc],workW5
00DA32  C44112     MSC W5*W6, A                   127:             msc       workW5*UnlimitW6,A          ; A = A - (Kc * Exc)
                                                  128:   
                                                  129:        ;; Sum = Sum + Ki * Err - Kc * Exc 
00DA34  CB0000     ADD A                          130:             add       A
                                                  131:   
                                                  132:        ;; Store the integrator
00DA36  CC0000     SAC A, W0                      133:             sac       A,workW0
00DA38  980090     MOV W0, [W1+2]                 134:             mov.w     workW0,[StateptrW1+PISTATE_integratorH] 
00DA3A  800110     MOV ACCA, W0                   135:             mov.w     ACCAL,workW0
00DA3C  980080     MOV W0, [W1+0]                 136:             mov.w     workW0,[StateptrW1+PISTATE_integratorL]
                                                  137:   
                                                  138:   	 ;; Return 1	  
00DA3E  200010     MOV #0x1, W0                   139:   		  mov.w     #1, workW0
00DA40  F90044     POP CORCON                     140:             pop       CORCON
00DA42  060000     RETURN                         141:             return
                                                  142:   
                                                  143:   	  .global   _MC_Sum_Assembly
                                                  144:             .global   MC_Sum_Assembly
                                                  145:   
                                                  146:   _MC_Sum_Assembly:
                                                  147:   MC_Sum_Assembly:
                                                  148:        ;; Save CORCON, then configure as needed
00DA44  F80044     PUSH CORCON                    149:             push      CORCON
00DA46  200E24     MOV #0xE2, W4                  150:             mov.w     #0x00E2,CorconW4
00DA48  880224     MOV W4, CORCON                 151:             mov.w     CorconW4,CORCON
                                                  152:   	 ;; workW0 : SUM_PARAMIN*
00DA4A  780080     MOV W0, W1                     153:   	  mov.w	    workW0,StateptrW1
00DA4C  780103     MOV W3, W2                     154:   	  mov.w     workW3,OutptrW2
00DA4E  900001     MOV [W1+0], W0                 155:   	  mov.w	    [StateptrW1+SUM_PARMIN_S1_in],workW0
00DA50  CA0000     LAC W0, A                      156:             lac       workW0,#0,A
00DA52  900011     MOV [W1+2], W0                 157:   	  mov.w	    [StateptrW1+SUM_PARMIN_S2_in],workW0
00DA54  CA8000     LAC W0, B                      158:             lac       workW0,#0,B
00DA56  CB0000     ADD A                          159:             add       A
00DA58  9003A1     MOV [W1+4], W7                 160:   	  mov.w	    [StateptrW1+SUM_PARMIN_S3_in],workW7
00DA5A  9002B1     MOV [W1+6], W5                 161:   	  mov.w	    [StateptrW1+SUM_PARMIN_omegaL_in],workW5
00DA5C  C58113     MPY W5*W7, B                   162:   	  mpy       workW7*workW5,B
00DA5E  CB0000     ADD A                          163:   	  add	    A
00DA60  CC0006     SAC A, W6                      164:             sac       A,#0,UnlimitW6
                                                  165:   
                                                  166:   
                                                  167:        ;; if( U > Outmax )
                                                  168:        ;;     Out = Outmax
                                                  169:        ;; else if( U < Outmin )
                                                  170:        ;;     Out = Outmin
                                                  171:        ;; else        
                                                  172:        ;;     Out = U 
                                                  173:   
00DA62  9001C1     MOV [W1+8], W3                 174:             mov.w     [StateptrW1+SUM_PARMIN_out_Max],OutW3
00DA64  E13003     CP W6, W3                      175:             cp        UnlimitW6,OutW3
00DA66  3C0004     BRA GT, 0xDA70                 176:             bra       GT,jS5             ; U > Outmax; OutW3 = Outmax
                                                  177:   
00DA68  9001D1     MOV [W1+10], W3                178:             mov.w     [StateptrW1+SUM_PARMIN_out_Min],OutW3
00DA6A  E13003     CP W6, W3                      179:             cp        UnlimitW6,OutW3
00DA6C  340001     BRA LE, 0xDA70                 180:             bra       LE,jS5             ; U < Outmin; OutW3 = Outmin
                                                  181:   
00DA6E  780186     MOV W6, W3                     182:             mov.w     UnlimitW6,OutW3     ; OutW3 = U
                                                  183:   jS5:
00DA70  780903     MOV W3, [W2]                   184:             mov.w     OutW3,[OutptrW2]
                                                  185:   
                                                  186:        
                                                  187:   	 ;; Return 1	  
00DA72  200010     MOV #0x1, W0                   188:   	  mov.w     #1, workW0
00DA74  F90044     POP CORCON                     189:             pop       CORCON
00DA76  060000     RETURN                         190:             return
