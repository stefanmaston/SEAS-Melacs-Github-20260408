755:               int BSP_UART_2_Send_Data_Blocking(const void  *data, uint16_t length)
756:               {
00A3B0  FA000A     LNK #0xA
00A3B2  980730     MOV W0, [W14+6]
00A3B4  980741     MOV W1, [W14+8]
757:               	//
758:               	// Message sent using blocking method (prevent ring buffer overflow)
759:               	//
760:               	int pass, sent = 0;
00A3B6  EB0000     CLR W0
00A3B8  780F00     MOV W0, [W14]
761:               	uint8_t *p8 = (uint8_t*)data;
00A3BA  9000BE     MOV [W14+6], W1
00A3BC  980711     MOV W1, [W14+2]
762:               
763:               	while(length > 0) {
00A3BE  37000F     BRA 0xA3DE
00A3DE  90004E     MOV [W14+8], W0
00A3E0  E00000     CP0 W0
00A3E2  3AFFEE     BRA NZ, 0xA3C0
764:               		pass = BlockWriteUART2(p8, length);
00A3C0  90004E     MOV [W14+8], W0
00A3C2  780080     MOV W0, W1
00A3C4  90001E     MOV [W14+2], W0
00A3C6  07FFD9     RCALL BlockWriteUART2
00A3C8  980720     MOV W0, [W14+4]
765:               		length -= pass;
00A3CA  90002E     MOV [W14+4], W0
00A3CC  9000CE     MOV [W14+8], W1
00A3CE  508000     SUB W1, W0, W0
00A3D0  980740     MOV W0, [W14+8]
766:               		sent += pass;
00A3D2  90002E     MOV [W14+4], W0
00A3D4  400F1E     ADD W0, [W14], [W14]
767:               		p8 += pass;
00A3D6  90002E     MOV [W14+4], W0
00A3D8  90009E     MOV [W14+2], W1
00A3DA  408000     ADD W1, W0, W0
00A3DC  980710     MOV W0, [W14+2]
768:               	}
769:               	return sent;
00A3E4  78001E     MOV [W14], W0
770:               }
00A3E6  FA8000     ULNK
00A3E8  060000     RETURN
