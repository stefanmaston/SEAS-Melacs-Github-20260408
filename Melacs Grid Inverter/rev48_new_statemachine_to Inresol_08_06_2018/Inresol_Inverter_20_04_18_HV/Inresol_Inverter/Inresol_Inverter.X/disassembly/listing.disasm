                                                  23:              .include "mc_interfaces_dspic.inc"
                                                  24:    ; Inputs:
                                                  25:    ;  ABC.a
                                                  26:    ;  ABC.b
                                                  27:    ;  ABC.c
                                                  28:    ;  iPwmPeriod
                                                  29:    
                                                  30:    ; Outputs:
                                                  31:    ;  DUTYCYCLEOUT.dutycycle1
                                                  32:    ;  DUTYCYCLEOUT.dutycycle2
                                                  33:    ;  DUTYCYCLEOUT.dutycycle3
                                                  34:    
                                                  35:    ; Register usage
                                                  36:              .equ workW0,      w0  ; Working register             
                                                  37:              .equ workW1,      w1  ; Working register
                                                  38:              .equ workW2,      w2  ; working register          
                                                  39:                            
                                                  40:              .equ t1W2,        w2
                                                  41:              .equ t2W3,        w3
                                                  42:                            
                                                  43:              .equ workDLoW4,   w4  ; double word (multiply results)
                                                  44:              .equ aW4,         w4
                                                  45:              .equ taW4,        w4
                                                  46:              .equ workDHiW5,   w5  ; double word (multiply results)
                                                  47:              .equ bW5,         w5
                                                  48:              .equ tbW5,        w5
                                                  49:              .equ cW6,         w6
                                                  50:              .equ tcW6,        w6
                                                  51:    		  .equ pwmperW7,    w7
                                                  52:              
                                                  53:    		  .equ BaseptrW10,  w10
                                                  54:    		  
                                                  55:    ;=================== CODE =====================
                                                  56:    
                                                  57:              .section  .text
                                                  58:              .global   _MC_CalculateSpaceVectorPhaseShifted_Assembly
                                                  59:              .global   MC_CalculateSpaceVectorPhaseShifted_Assembly
                                                  60:    
                                                  61:    _MC_CalculateSpaceVectorPhaseShifted_Assembly:
                                                  62:    MC_CalculateSpaceVectorPhaseShifted_Assembly:
                                                  63:         ;; workW0 : ABC*
                                                  64:         ;; workW1 : iPwmPeriod
                                                  65:         ;; workW2 : DUTYCYCLEOUT*
00D282  781F8A     MOV W10, [W15++]               66:              push       BaseptrW10
00D284  780500     MOV W0, W10                    67:    	      mov.w      workW0,BaseptrW10
00D286  780381     MOV W1, W7                     68:              mov.w      workW1,pwmperW7
                                                  69:    	 
                                                  70:         ;; Get a,b,c
00D288  90020A     MOV [W10+0], W4                71:              mov.w     [BaseptrW10+ABC_a],aW4
00D28A  90029A     MOV [W10+2], W5                72:              mov.w     [BaseptrW10+ABC_b],bW5
00D28C  90032A     MOV [W10+4], W6                73:              mov.w     [BaseptrW10+ABC_c],cW6
00D28E  780502     MOV W2, W10                    74:              mov.w      workW2,BaseptrW10
                                                  75:    
                                                  76:         ;; Test a
00D290  E00004     CP0 W4                         77:              cp0       aW4
00D292  350040     BRA LT, 0xD314                 78:              bra       LT,jCalcRef20       ; aW4 < 0
                                                  79:    
                                                  80:         ;; Test b
00D294  E00005     CP0 W5                         81:              cp0       bW5
00D296  350014     BRA LT, 0xD2C0                 82:              bra       LT,jCalcRef10       ; bW5 < 0
                                                  83:    
                                                  84:         ;; Must be Sector 3 since Sector 7 not allowed
                                                  85:         ;; Sector 3: (0,1,1)  0-60 degrees
                                                  86:    
                                                  87:         ;; T1 = a
                                                  88:         ;; T2 = b
00D298  780185     MOV W5, W3                     89:              mov.w     bW5,t2W3
00D29A  780104     MOV W4, W2                     90:              mov.w     aW4,t1W2
                                                  91:    
                                                  92:         ;; Since T1 is in 1.15 and PWM in integer we do multiply by
                                                  93:         ;; PWM*T1 as integers and use upper word of results
                                                  94:    
                                                  95:         ;; Load PWMPeriod
00D29C  780007     MOV W7, W0                     96:              mov.w	    pwmperW7,workW0
00D29E  D00000     SL W0, W0                      97:    		  sl.w      workW0,workW0
                                                  98:    		  
                                                  99:         ;; T1 = PWM*T1		  
00D2A0  B88202     MUL.US  W0, W2, W4             100:             mul.us    workW0,t1W2,workDLoW4
00D2A2  780105     MOV W5, W2                     101:             mov.w     workDHiW5,t1W2
                                                  102:   
                                                  103:        ;; T2 = PWM*T2
00D2A4  B88203     MUL.US  W0, W3, W4             104:             mul.us    workW0,t2W3,workDLoW4
00D2A6  780185     MOV W5, W3                     105:             mov.w     workDHiW5,t2W3
                                                  106:   
                                                  107:        ;; Tc = (PWM-T1-T2)/2
00D2A8  538082     SUB W7, W2, W1                 108:             sub.w     pwmperW7,t1W2,workW1     ;PWM-T1
00D2AA  508083     SUB W1, W3, W1                 109:             sub.w     workW1,t2W3,workW1     ; -T2
00D2AC  D18081     ASR W1, W1                     110:             asr.w     workW1,workW1          ; /2
00D2AE  780301     MOV W1, W6                     111:             mov.w     workW1,tcW6            ; store Tc
                                                  112:   
                                                  113:        ;; Tb = Tc + T1
00D2B0  408082     ADD W1, W2, W1                 114:             add.w     workW1,t1W2,workW1
00D2B2  780281     MOV W1, W5                     115:             mov.w     workW1,tbW5
                                                  116:   
                                                  117:        ;; Ta = Tb + T2
00D2B4  408083     ADD W1, W3, W1                 118:             add.w     workW1,t2W3,workW1
00D2B6  780201     MOV W1, W4                     119:             mov.w     workW1,taW4
                                                  120:   
                                                  121:        ;; dutycycle1 = Ta
                                                  122:        ;; dutycycle2 = Tb
                                                  123:        ;; dutycycle3 = Tc
00D2B8  980504     MOV W4, [W10+0]                124:             mov.w     taW4,[BaseptrW10+DUTYCYCLEOUT_dutycycle1]
00D2BA  980515     MOV W5, [W10+2]                125:             mov.w     tbW5,[BaseptrW10+DUTYCYCLEOUT_dutycycle2]
00D2BC  980526     MOV W6, [W10+4]                126:             mov.w     tcW6,[BaseptrW10+DUTYCYCLEOUT_dutycycle3]
00D2BE  370069     BRA 0xD392                     127:             bra		exitSVM
                                                  128:   
                                                  129:   jCalcRef10:
                                                  130:        ;; Test c
00D2C0  E00006     CP0 W6                         131:             cp0       cW6
00D2C2  350014     BRA LT, 0xD2EC                 132:             bra       LT,jCalcRef15       ; cW6 < 0
                                                  133:   
                                                  134:        ;; Sector 5: (1,0,1)  120-180 degrees
                                                  135:        ;; T1 = c
                                                  136:        ;; T2 = a
00D2C4  780184     MOV W4, W3                     137:             mov.w     aW4,t2W3
00D2C6  780106     MOV W6, W2                     138:             mov.w     cW6,t1W2
                                                  139:   
                                                  140:        ;; Since T1 is in 1.15 and PWM in integer we do multiply by
                                                  141:        ;; PWM*T1 as integers and use upper word of results
                                                  142:   
                                                  143:        ;; Load PWMPeriod
00D2C8  780007     MOV W7, W0                     144:             mov.w	    pwmperW7,workW0
00D2CA  D00000     SL W0, W0                      145:   		  sl.w      workW0,workW0
                                                  146:   
                                                  147:        ;; T1 = PWM*T1
00D2CC  B88202     MUL.US  W0, W2, W4             148:             mul.us    workW0,t1W2,workDLoW4
00D2CE  780105     MOV W5, W2                     149:             mov.w     workDHiW5,t1W2
                                                  150:   
                                                  151:        ;; T2 = PWM*T2
00D2D0  B88203     MUL.US  W0, W3, W4             152:             mul.us    workW0,t2W3,workDLoW4
00D2D2  780185     MOV W5, W3                     153:             mov.w     workDHiW5,t2W3
                                                  154:   
                                                  155:        ;; Tc = (PWM-T1-T2)/2
00D2D4  538082     SUB W7, W2, W1                 156:             sub.w     pwmperW7,t1W2,workW1     ;PWM-T1
00D2D6  508083     SUB W1, W3, W1                 157:             sub.w     workW1,t2W3,workW1     ; -T2
00D2D8  D18081     ASR W1, W1                     158:             asr.w     workW1,workW1          ; /2
00D2DA  780301     MOV W1, W6                     159:             mov.w     workW1,tcW6            ; store Tc
                                                  160:   
                                                  161:        ;; Tb = Tc + T1
00D2DC  408082     ADD W1, W2, W1                 162:             add.w     workW1,t1W2,workW1
00D2DE  780281     MOV W1, W5                     163:             mov.w     workW1,tbW5
                                                  164:   
                                                  165:        ;; Ta = Tb + T2
00D2E0  408083     ADD W1, W3, W1                 166:             add.w     workW1,t2W3,workW1
00D2E2  780201     MOV W1, W4                     167:             mov.w     workW1,taW4
                                                  168:   
                                                  169:        ;; dutycycle1 = Tc
                                                  170:        ;; dutycycle2 = Ta
                                                  171:        ;; dutycycle3 = Tb
00D2E4  980506     MOV W6, [W10+0]                172:             mov.w     tcW6,[BaseptrW10+DUTYCYCLEOUT_dutycycle1]
00D2E6  980514     MOV W4, [W10+2]                173:             mov.w     taW4,[BaseptrW10+DUTYCYCLEOUT_dutycycle2]
00D2E8  980525     MOV W5, [W10+4]                174:             mov.w     tbW5,[BaseptrW10+DUTYCYCLEOUT_dutycycle3]
00D2EA  370053     BRA 0xD392                     175:             bra		exitSVM
                                                  176:   
                                                  177:   jCalcRef15:
                                                  178:   
                                                  179:        ;; Sector 1: (0,0,1)  60-120 degrees
                                                  180:        ;; T1 = -c
                                                  181:        ;; T2 = -b
00D2EC  EA0185     NEG W5, W3                     182:             neg.w     bW5,t2W3
00D2EE  EA0106     NEG W6, W2                     183:             neg.w     cW6,t1W2
                                                  184:   
                                                  185:        ;; Since T1 is in 1.15 and PWM in integer we do multiply by
                                                  186:        ;; PWM*T1 as integers and use upper word of results
                                                  187:   
                                                  188:        ;; Load PWMPeriod
00D2F0  780007     MOV W7, W0                     189:             mov.w	    pwmperW7,workW0
00D2F2  D00000     SL W0, W0                      190:   		  sl.w      workW0,workW0
                                                  191:   
                                                  192:        ;; T1 = PWM*T1
00D2F4  B88202     MUL.US  W0, W2, W4             193:             mul.us    workW0,t1W2,workDLoW4
00D2F6  780105     MOV W5, W2                     194:             mov.w     workDHiW5,t1W2
                                                  195:   
                                                  196:        ;; T2 = PWM*T2
00D2F8  B88203     MUL.US  W0, W3, W4             197:             mul.us    workW0,t2W3,workDLoW4
00D2FA  780185     MOV W5, W3                     198:             mov.w     workDHiW5,t2W3
                                                  199:   
                                                  200:        ;; Tc = (PWM-T1-T2)/2
00D2FC  538082     SUB W7, W2, W1                 201:             sub.w     pwmperW7,t1W2,workW1     ;PWM-T1
00D2FE  508083     SUB W1, W3, W1                 202:             sub.w     workW1,t2W3,workW1     ; -T2
00D300  D18081     ASR W1, W1                     203:             asr.w     workW1,workW1          ; /2
00D302  780301     MOV W1, W6                     204:             mov.w     workW1,tcW6            ; store Tc
                                                  205:   
                                                  206:        ;; Tb = Tc + T1
00D304  408082     ADD W1, W2, W1                 207:             add.w     workW1,t1W2,workW1
00D306  780281     MOV W1, W5                     208:             mov.w     workW1,tbW5
                                                  209:   
                                                  210:        ;; Ta = Tb + T2
00D308  408083     ADD W1, W3, W1                 211:             add.w     workW1,t2W3,workW1
00D30A  780201     MOV W1, W4                     212:             mov.w     workW1,taW4
                                                  213:   
                                                  214:        ;; dutycycle1 = Tb
                                                  215:        ;; dutycycle2 = Ta
                                                  216:        ;; dutycycle3 = Tc
00D30C  980505     MOV W5, [W10+0]                217:             mov.w     tbW5,[BaseptrW10+DUTYCYCLEOUT_dutycycle1]
00D30E  980514     MOV W4, [W10+2]                218:             mov.w     taW4,[BaseptrW10+DUTYCYCLEOUT_dutycycle2]
00D310  980526     MOV W6, [W10+4]                219:             mov.w     tcW6,[BaseptrW10+DUTYCYCLEOUT_dutycycle3]
00D312  37003F     BRA 0xD392                     220:             bra		exitSVM
                                                  221:   
                                                  222:   jCalcRef20:
                                                  223:   
                                                  224:        ;; Test b
00D314  E00005     CP0 W5                         225:             cp0       bW5
00D316  35002A     BRA LT, 0xD36C                 226:             bra       LT,jCalcRef30       ; bW5 < 0
                                                  227:   
                                                  228:        ;; Test c
00D318  E00006     CP0 W6                         229:             cp0       cW6
00D31A  350014     BRA LT, 0xD344                 230:             bra       LT,jCalcRef25       ; cW6 < 0
                                                  231:   
                                                  232:        ;; Sector 6: (1,1,0)  240-300 degrees
                                                  233:        ;; T1 = b
                                                  234:        ;; T2 = c
00D31C  780186     MOV W6, W3                     235:             mov.w     cW6,t2W3
00D31E  780105     MOV W5, W2                     236:             mov.w     bW5,t1W2
                                                  237:   
                                                  238:        ;; Since T1 is in 1.15 and PWM in integer we do multiply by
                                                  239:        ;; PWM*T1 as integers and use upper word of results
                                                  240:   
                                                  241:        ;; Load PWMPeriod
00D320  780007     MOV W7, W0                     242:             mov.w	    pwmperW7,workW0
00D322  D00000     SL W0, W0                      243:   		  sl.w      workW0,workW0
                                                  244:   
                                                  245:        ;; T1 = PWM*T1
00D324  B88202     MUL.US  W0, W2, W4             246:             mul.us    workW0,t1W2,workDLoW4
00D326  780105     MOV W5, W2                     247:             mov.w     workDHiW5,t1W2
                                                  248:   
                                                  249:        ;; T2 = PWM*T2
00D328  B88203     MUL.US  W0, W3, W4             250:             mul.us    workW0,t2W3,workDLoW4
00D32A  780185     MOV W5, W3                     251:             mov.w     workDHiW5,t2W3
                                                  252:   
                                                  253:        ;; Tc = (PWM-T1-T2)/2
00D32C  538082     SUB W7, W2, W1                 254:             sub.w     pwmperW7,t1W2,workW1     ;PWM-T1
00D32E  508083     SUB W1, W3, W1                 255:             sub.w     workW1,t2W3,workW1     ; -T2
00D330  D18081     ASR W1, W1                     256:             asr.w     workW1,workW1          ; /2
00D332  780301     MOV W1, W6                     257:             mov.w     workW1,tcW6            ; store Tc
                                                  258:   
                                                  259:        ;; Tb = Tc + T1
00D334  408082     ADD W1, W2, W1                 260:             add.w     workW1,t1W2,workW1
00D336  780281     MOV W1, W5                     261:             mov.w     workW1,tbW5
                                                  262:   
                                                  263:        ;; Ta = Tb + T2
00D338  408083     ADD W1, W3, W1                 264:             add.w     workW1,t2W3,workW1
00D33A  780201     MOV W1, W4                     265:             mov.w     workW1,taW4
                                                  266:   
                                                  267:        ;; dutycycle1 = Tb
                                                  268:        ;; dutycycle2 = Tc
                                                  269:        ;; dutycycle3 = Ta
00D33C  980505     MOV W5, [W10+0]                270:             mov.w     tbW5,[BaseptrW10+DUTYCYCLEOUT_dutycycle1]
00D33E  980516     MOV W6, [W10+2]                271:             mov.w     tcW6,[BaseptrW10+DUTYCYCLEOUT_dutycycle2]
00D340  980524     MOV W4, [W10+4]                272:             mov.w     taW4,[BaseptrW10+DUTYCYCLEOUT_dutycycle3]
00D342  370027     BRA 0xD392                     273:             bra		exitSVM
                                                  274:   
                                                  275:   jCalcRef25:
                                                  276:        ;; Sector 2: (0,1,0)  300-360 degrees
                                                  277:        ;; T1 = -a
                                                  278:        ;; T2 = -c
00D344  EA0186     NEG W6, W3                     279:             neg.w     cW6,t2W3
00D346  EA0104     NEG W4, W2                     280:             neg.w     aW4,t1W2
                                                  281:   
                                                  282:        ;; Since T1 is in 1.15 and PWM in integer we do multiply by
                                                  283:        ;; PWM*T1 as integers and use upper word of results
                                                  284:   
                                                  285:        ;; Load PWMPeriod
00D348  780007     MOV W7, W0                     286:             mov.w	    pwmperW7,workW0
00D34A  D00000     SL W0, W0                      287:   		  sl.w      workW0,workW0
                                                  288:   
                                                  289:        ;; T1 = PWM*T1
00D34C  B88202     MUL.US  W0, W2, W4             290:             mul.us    workW0,t1W2,workDLoW4
00D34E  780105     MOV W5, W2                     291:             mov.w     workDHiW5,t1W2
                                                  292:   
                                                  293:        ;; T2 = PWM*T2
00D350  B88203     MUL.US  W0, W3, W4             294:             mul.us    workW0,t2W3,workDLoW4
00D352  780185     MOV W5, W3                     295:             mov.w     workDHiW5,t2W3
                                                  296:   
                                                  297:        ;; Tc = (PWM-T1-T2)/2
00D354  538082     SUB W7, W2, W1                 298:             sub.w     pwmperW7,t1W2,workW1     ;PWM-T1
00D356  508083     SUB W1, W3, W1                 299:             sub.w     workW1,t2W3,workW1     ; -T2
00D358  D18081     ASR W1, W1                     300:             asr.w     workW1,workW1          ; /2
00D35A  780301     MOV W1, W6                     301:             mov.w     workW1,tcW6            ; store Tc
                                                  302:   
                                                  303:        ;; Tb = Tc + T1
00D35C  408082     ADD W1, W2, W1                 304:             add.w     workW1,t1W2,workW1
00D35E  780281     MOV W1, W5                     305:             mov.w     workW1,tbW5
                                                  306:   
                                                  307:        ;; Ta = Tb + T2
00D360  408083     ADD W1, W3, W1                 308:             add.w     workW1,t2W3,workW1
00D362  780201     MOV W1, W4                     309:             mov.w     workW1,taW4
                                                  310:   
                                                  311:        ;; dutycycle1 = Ta
                                                  312:        ;; dutycycle2 = Tc
                                                  313:        ;; dutycycle3 = Tb
00D364  980504     MOV W4, [W10+0]                314:             mov.w     taW4,[BaseptrW10+DUTYCYCLEOUT_dutycycle1]
00D366  980516     MOV W6, [W10+2]                315:             mov.w     tcW6,[BaseptrW10+DUTYCYCLEOUT_dutycycle2]
00D368  980525     MOV W5, [W10+4]                316:             mov.w     tbW5,[BaseptrW10+DUTYCYCLEOUT_dutycycle3]
00D36A  370013     BRA 0xD392                     317:             bra		exitSVM
                                                  318:   
                                                  319:   jCalcRef30:
                                                  320:        ;; Must be Sector 4 since Sector 0 not allowed
                                                  321:        ;; Sector 4: (1,0,0)  180-240 degrees
                                                  322:   
                                                  323:        ;; T1 = -b
                                                  324:        ;; T2 = -a
00D36C  EA0184     NEG W4, W3                     325:             neg.w     aW4,t2W3
00D36E  EA0105     NEG W5, W2                     326:             neg.w     bW5,t1W2
                                                  327:   
                                                  328:        ;; Since T1 is in 1.15 and PWM in integer we do multiply by
                                                  329:        ;; PWM*T1 as integers and use upper word of results
                                                  330:   
                                                  331:        ;; Load PWMPeriod
00D370  780007     MOV W7, W0                     332:             mov.w	    pwmperW7,workW0
00D372  D00000     SL W0, W0                      333:   		  sl.w      workW0,workW0
                                                  334:   
                                                  335:        ;; T1 = PWM*T1
00D374  B88202     MUL.US  W0, W2, W4             336:             mul.us    workW0,t1W2,workDLoW4
00D376  780105     MOV W5, W2                     337:             mov.w     workDHiW5,t1W2
                                                  338:   
                                                  339:        ;; T2 = PWM*T2
00D378  B88203     MUL.US  W0, W3, W4             340:             mul.us    workW0,t2W3,workDLoW4
00D37A  780185     MOV W5, W3                     341:             mov.w     workDHiW5,t2W3
                                                  342:   
                                                  343:        ;; Tc = (PWM-T1-T2)/2
00D37C  538082     SUB W7, W2, W1                 344:             sub.w     pwmperW7,t1W2,workW1     ;PWM-T1
00D37E  508083     SUB W1, W3, W1                 345:             sub.w     workW1,t2W3,workW1     ; -T2
00D380  D18081     ASR W1, W1                     346:             asr.w     workW1,workW1          ; /2
00D382  780301     MOV W1, W6                     347:             mov.w     workW1,tcW6            ; store Tc
                                                  348:   
                                                  349:        ;; Tb = Tc + T1
00D384  408082     ADD W1, W2, W1                 350:             add.w     workW1,t1W2,workW1
00D386  780281     MOV W1, W5                     351:             mov.w     workW1,tbW5
                                                  352:   
                                                  353:        ;; Ta = Tb + T2
00D388  408083     ADD W1, W3, W1                 354:             add.w     workW1,t2W3,workW1
00D38A  780201     MOV W1, W4                     355:             mov.w     workW1,taW4
                                                  356:   
                                                  357:        ;; dutycycle1 = Tc
                                                  358:        ;; dutycycle2 = Tb
                                                  359:        ;; dutycycle3 = Ta
00D38C  980506     MOV W6, [W10+0]                360:             mov.w     tcW6,[BaseptrW10+DUTYCYCLEOUT_dutycycle1]
00D38E  980515     MOV W5, [W10+2]                361:             mov.w     tbW5,[BaseptrW10+DUTYCYCLEOUT_dutycycle2]
00D390  980524     MOV W4, [W10+4]                362:             mov.w     taW4,[BaseptrW10+DUTYCYCLEOUT_dutycycle3]
                                                  363:   
                                                  364:   exitSVM:
                                                  365:   	 ;; Return 1	  
00D392  200010     MOV #0x1, W0                   366:   		  mov.w     #1, workW0
00D394  78054F     MOV [--W15], W10               367:             pop       BaseptrW10          
00D396  060000     RETURN                         368:             return
                                                  369:   
                                                  370:   
                                                  371:   
                                                  372:   
---  C:/Projects/Microchip/Workspace/Inresol_Inverter/lib_src/mc_sinecos_ram_dspic.s  -------------------
                                                  1:     ;*********************************************************************************
                                                  2:     ; Copyright (c) 2013 released Microchip Technology Inc.  All rights reserved.
                                                  3:     ; Microchip licenses to you the right to use, modify, copy and distribute
                                                  4:     ; Software only when embedded on a Microchip microcontroller or digital signal
                                                  5:     ; controller that is integrated into your product or third party product
                                                  6:     ; (pursuant to the sublicense terms in the accompanying license agreement).
                                                  7:     ; 
                                                  8:     ; You should refer to the license agreement accompanying this Software for
                                                  9:     ; additional information regarding your rights and obligations.
                                                  10:    ; 
                                                  11:    ; SOFTWARE AND DOCUMENTATION ARE PROVIDED "AS IS" WITHOUT WARRANTY OF ANY KIND,
                                                  12:    ; EITHER EXPRESS OR IMPLIED, INCLUDING WITHOUT LIMITATION, ANY WARRANTY OF
                                                  13:    ; MERCHANTABILITY, TITLE, NON-INFRINGEMENT AND FITNESS FOR A PARTICULAR PURPOSE.
                                                  14:    ; IN NO EVENT SHALL MICROCHIP OR ITS LICENSORS BE LIABLE OR OBLIGATED UNDER
                                                  15:    ; CONTRACT, NEGLIGENCE, STRICT LIABILITY, CONTRIBUTION, BREACH OF WARRANTY, OR
                                                  16:    ; OTHER LEGAL EQUITABLE THEORY ANY DIRECT OR INDIRECT DAMAGES OR EXPENSES
                                                  17:    ; INCLUDING BUT NOT LIMITED TO ANY INCIDENTAL, SPECIAL, INDIRECT, PUNITIVE OR
                                                  18:    ; CONSEQUENTIAL DAMAGES, LOST PROFITS OR LOST DATA, COST OF PROCUREMENT OF
                                                  19:    ; SUBSTITUTE GOODS, TECHNOLOGY, SERVICES, OR ANY CLAIMS BY THIRD PARTIES
                                                  20:    ; (INCLUDING BUT NOT LIMITED TO ANY DEFENSE THEREOF), OR OTHER SIMILAR COSTS.
                                                  21:    ;*********************************************************************************
                                                  22:    
                                                  23:             .include "mc_interfaces_dspic.inc"
                                                  24:    ; Inputs:
                                                  25:    ;  Angle
                                                  26:    
                                                  27:    ; Outputs:
                                                  28:    ;  SINCOS.sin
                                                  29:    ;  SINCOS.cos
                                                  30:    
                                                  31:    ; Constants
                                                  32:              .equ TableSize,128
                                                  33:    
                                                  34:    ; Local register usage
                                                  35:              .equ workW0,      w0  ; Working register
                                                  36:              .equ workW1,      w1  ; Working register
                                                  37:    
                                                  38:              .equ remainderW2, w2  ; Fraction for interpolation: 0->0xFFFF
                                                  39:              .equ indexW3,     w3  ; Index into table
                                                  40:    
                                                  41:              .equ pTabPtrW4,   w4  ; Pointer into table 
                                                  42:              .equ pTabBaseW5,  w5  ; Pointer into table base
                                                  43:    
                                                  44:              .equ y0W6,        w6  ; Y0 = mcSineTableInRam[Index]
                                                  45:              .equ angleW7,     w7  ; Angle
                                                  46:    		  
                                                  47:    		  .equ BaseptrW10, w10
                                                  48:    
                                                  49:          ;; Note: remainderW2 and workW0 must be even registers
                                                  50:    
                                                  51:    
                                                  52:    ;=================== CODE =====================
                                                  53:    
                                                  54:              .section  .text
                                                  55:              .global   _MC_CalculateSineCosine_Assembly_Ram
                                                  56:              .global   MC_CalculateSineCosine_Assembly_Ram
                                                  57:    
                                                  58:    _MC_CalculateSineCosine_Assembly_Ram:
                                                  59:    MC_CalculateSineCosine_Assembly_Ram:
                                                  60:         ;; workW0 : Angle
                                                  61:    	 ;; workW1 : SINCOS*
00DC66  780380     MOV W0, W7                     62:              mov.w     workW0,angleW7
00DC68  781F8A     MOV W10, [W15++]               63:              push      BaseptrW10          
00DC6A  780501     MOV W1, W10                    64:    	      mov.w     workW1,BaseptrW10
                                                  65:    
00DC6C  213005     MOV #0x1300, W5                66:              mov.w     #mcSineTableInRam,pTabBaseW5     ; Pointer into table base		  
                                                  67:    
                                                  68:         ;; Calculate Index and Remainder for fetching and interpolating Sin
00DC6E  200800     MOV #0x80, W0                  69:              mov.w     #TableSize,workW0
00DC70  B80107     MUL.UU W0, W7, W2              70:              mul.uu    workW0,angleW7,remainderW2   ; high word in indexW3
                                                  71:    
                                                  72:         ;; Double Index since offsets are in bytes not words
00DC72  418183     ADD W3, W3, W3                 73:              add.w     indexW3,indexW3,indexW3
                                                  74:    
                                                  75:         ;; Note at this point the indexW3 register has a value 0x00nn where nn
                                                  76:         ;; is the offset in bytes from the TabBase.  If below we always
                                                  77:         ;; use BYTE operations on the indexW3 register it will automatically
                                                  78:         ;; wrap properly for a TableSize of 128.  
                                                  79:    
                                                  80:         ;; Check for zero remainder
00DC74  E00002     CP0 W2                         81:              cp0.w     remainderW2
00DC76  3A000A     BRA NZ, 0xDC8C                 82:              bra       nz,jInterpolate
                                                  83:    
                                                  84:         ;; Zero remainder allows us to skip the interpolation and use the 
                                                  85:         ;; table value directly
00DC78  418205     ADD W3, W5, W4                 86:              add.w     indexW3,pTabBaseW5,pTabPtrW4
00DC7A  780014     MOV [W4], W0                   87:              mov.w     [pTabPtrW4],workW0    
00DC7C  980510     MOV W0, [W10+2]                88:    		  mov.w     workW0,[BaseptrW10+SINCOS_sin]  ; write to qSin
                                                  89:    
                                                  90:         ;; Add 0x40 to Sin index to get Cos index.  This may go off end of
                                                  91:         ;; table but if we use only BYTE operations the wrap is automatic.
00DC7E  B04403     ADD.B #0x40, W3                92:              add.b     #0x40,indexW3
00DC80  418205     ADD W3, W5, W4                 93:              add.w     indexW3,pTabBaseW5,pTabPtrW4
00DC82  780014     MOV [W4], W0                   94:              mov.w     [pTabPtrW4],workW0
00DC84  980500     MOV W0, [W10+0]                95:    		  mov.w     workW0,[BaseptrW10+SINCOS_cos]  ; write to qCos
                                                  96:    	  
                                                  97:    	 ;; Return 1	  
00DC86  200010     MOV #0x1, W0                   98:    		  mov.w     #1, workW0
00DC88  78054F     MOV [--W15], W10               99:              pop       BaseptrW10		  
00DC8A  060000     RETURN                         100:             return
                                                  101:   
                                                  102:   jInterpolate:
                                                  103:   
                                                  104:        ;; ================= SIN =========================
                                                  105:   
                                                  106:        ;; Get Y1-Y0 = mcSineTableInRam[Index+1] - mcSineTableInRam[Index]
00DC8C  418205     ADD W3, W5, W4                 107:             add.w     indexW3,pTabBaseW5,pTabPtrW4
00DC8E  780314     MOV [W4], W6                   108:             mov.w     [pTabPtrW4],y0W6              ; Y0
00DC90  E8C183     INC2.B W3, W3                  109:             inc2.b    indexW3,indexW3               ; (Index += 2)&0xFF
00DC92  418205     ADD W3, W5, W4                 110:             add.w     indexW3,pTabBaseW5,pTabPtrW4
00DC94  130014     SUBR W6, [W4], W0              111:             subr.w    y0W6,[pTabPtrW4],workW0      ; Y1 - Y0
                                                  112:     
                                                  113:        ;; Calcuate Delta = (Remainder*(Y1-Y0)) >> 16
00DC96  B89000     MUL.US  W2, W0, W0             114:             mul.us    remainderW2,workW0,workW0
                                                  115:   
                                                  116:        ;; workW1 contains upper word of (Remainder*(Y1-Y0)) 
                                                  117:        ;; *pSin = Y0 + Delta
00DC98  408006     ADD W1, W6, W0                 118:             add.w     workW1,y0W6,workW0
00DC9A  980510     MOV W0, [W10+2]                119:   		  mov.w     workW0,[BaseptrW10+SINCOS_sin]   ; write to qSin
                                                  120:   
                                                  121:        ;; ================= COS =========================
                                                  122:   
                                                  123:        ;; Add 0x40 to Sin index to get Cos index.  This may go off end of
                                                  124:        ;; table but if we use only BYTE operations the wrap is automatic.
                                                  125:        ;; Actualy only add 0x3E since Index increment by two above
00DC9C  B043E3     ADD.B #0x3E, W3                126:             add.b     #0x3E,indexW3
                                                  127:   
                                                  128:        ;; Get Y1-Y0 = mcSineTableInRam[Index+1] - mcSineTableInRam[Index]
00DC9E  418205     ADD W3, W5, W4                 129:             add.w     indexW3,pTabBaseW5,pTabPtrW4
00DCA0  780314     MOV [W4], W6                   130:             mov.w     [pTabPtrW4],y0W6              ; Y0
00DCA2  E8C183     INC2.B W3, W3                  131:             inc2.b    indexW3,indexW3               ; (Index += 2)&0xFF
00DCA4  418205     ADD W3, W5, W4                 132:             add.w     indexW3,pTabBaseW5,pTabPtrW4
00DCA6  130014     SUBR W6, [W4], W0              133:             subr.w    y0W6,[pTabPtrW4],workW0       ; Y1 - Y0
                                                  134:     
                                                  135:        ;; Calcuate Delta = (Remainder*(Y1-Y0)) >> 16
00DCA8  B89000     MUL.US  W2, W0, W0             136:             mul.us    remainderW2,workW0,workW0
                                                  137:   
                                                  138:        ;; workW1 contains upper word of (Remainder*(Y1-Y0)) 
                                                  139:        ;; *pCos = Y0 + Delta
00DCAA  408006     ADD W1, W6, W0                 140:             add.w     workW1,y0W6,workW0     
00DCAC  980500     MOV W0, [W10+0]                141:   		  mov.w     workW0,[BaseptrW10+SINCOS_cos]   ; write to qCos
                                                  142:   
                                                  143:   	 ;; Return 2
00DCAE  200020     MOV #0x2, W0                   144:   		  mov.w     #2, workW0		  
00DCB0  78054F     MOV [--W15], W10               145:             pop       BaseptrW10	  
00DCB2  060000     RETURN                         146:             return
                                                  147:   
                                                  148:             .end
---  C:/Projects/Microchip/Workspace/Inresol_Inverter/lib_src/mc_piupdate_dspic.s  ----------------------
                                                  1:     ;*********************************************************************************
                                                  2:     ; Copyright (c) 2013 released Microchip Technology Inc.  All rights reserved.
                                                  3:     ; Microchip licenses to you the right to use, modify, copy and distribute
                                                  4:     ; Software only when embedded on a Microchip microcontroller or digital signal
                                                  5:     ; controller that is integrated into your product or third party product
                                                  6:     ; (pursuant to the sublicense terms in the accompanying license agreement).
                                                  7:     ; 
                                                  8:     ; You should refer to the license agreement accompanying this Software for
                                                  9:     ; additional information regarding your rights and obligations.
                                                  10:    ; 
                                                  11:    ; SOFTWARE AND DOCUMENTATION ARE PROVIDED "AS IS" WITHOUT WARRANTY OF ANY KIND,
                                                  12:    ; EITHER EXPRESS OR IMPLIED, INCLUDING WITHOUT LIMITATION, ANY WARRANTY OF
                                                  13:    ; MERCHANTABILITY, TITLE, NON-INFRINGEMENT AND FITNESS FOR A PARTICULAR PURPOSE.
                                                  14:    ; IN NO EVENT SHALL MICROCHIP OR ITS LICENSORS BE LIABLE OR OBLIGATED UNDER
                                                  15:    ; CONTRACT, NEGLIGENCE, STRICT LIABILITY, CONTRIBUTION, BREACH OF WARRANTY, OR
                                                  16:    ; OTHER LEGAL EQUITABLE THEORY ANY DIRECT OR INDIRECT DAMAGES OR EXPENSES
                                                  17:    ; INCLUDING BUT NOT LIMITED TO ANY INCIDENTAL, SPECIAL, INDIRECT, PUNITIVE OR
                                                  18:    ; CONSEQUENTIAL DAMAGES, LOST PROFITS OR LOST DATA, COST OF PROCUREMENT OF
                                                  19:    ; SUBSTITUTE GOODS, TECHNOLOGY, SERVICES, OR ANY CLAIMS BY THIRD PARTIES
                                                  20:    ; (INCLUDING BUT NOT LIMITED TO ANY DEFENSE THEREOF), OR OTHER SIMILAR COSTS.
                                                  21:    ;*********************************************************************************
                                                  22:    
                                                  23:             .include "mc_interfaces_dspic.inc"
                                                  24:    ; Inputs:
                                                  25:    ;  PIPARMIN kp,ki,kc,out_Max,out_Min,in_Ref,in_Meas
                                                  26:    
                                                  27:    ; Outputs:
                                                  28:    ;  PIPARMOUT out
                                                  29:    
                                                  30:    ; Register usage
                                                  31:    
                                                  32:              .equ workW0,   w0  ; Working register
                                                  33:              .equ workW1,   w1  ; Working register (function I/O only, don't reuse)
                                                  34:              .equ workW2,   w2  ; Working register (function I/O only, don't reuse)
                                                  35:              .equ workW3,   w3  ; Working register (function I/O only, don't reuse)
                                                  36:    		  
                                                  37:              .equ StateptrW1,   w1   ; PI state pointer
                                                  38:              .equ OutptrW2,     w2   ; Pointer to out
                                                  39:              .equ OutW3,        w3   ; Output
                                                  40:              .equ ErrW4,        w4   ; Error term: in_Ref-in_Meas
                                                  41:              .equ CorconW4,     w4   ; CORCON temp
                                                  42:              .equ workW5,       w5   ; Working register
                                                  43:              .equ UnlimitW6,    w6   ; U: unlimited output 
                                                  44:              .equ workW7,       w7   ; Working register
                                                  45:    
                                                  46:    ; Constants		  
                                                  47:    		  .equ NKo,4 ; PI scaling coeff
                                                  48:    
                                                  49:    ; Note
                                                  50:    ;  This function requires CORCON register to be setup in a certain state
                                                  51:    ;  in order to operate correctly. Due to this requirement, this function
                                                  52:    ;  will save the CORCON register on the stack in the beginning of the
                                                  53:    ;  function and restore it before the function return.
                                                  54:    ;  After saving the CORCON register, this function writes to all bits of
                                                  55:    ;  the CORCON register. Thus, for the brief duration when this function is
                                                  56:    ;  executing, the state of CORCON register may be different from its state
                                                  57:    ;  as set by the function caller. This may change the CPU core behavior with
                                                  58:    ;  respect to exception processing latency, DO loop termination, CPU interrupt
                                                  59:    ;  priority level and DSP-engine behavior.
                                                  60:    
                                                  61:    ;=================== CODE =====================
                                                  62:    
                                                  63:              .section  .text
                                                  64:              .global   _MC_ControllerPIUpdate_Assembly
                                                  65:              .global   MC_ControllerPIUpdate_Assembly
                                                  66:    
                                                  67:    _MC_ControllerPIUpdate_Assembly:
                                                  68:    MC_ControllerPIUpdate_Assembly:
                                                  69:         ;; Save CORCON, then configure as needed
00DC18  F80044     PUSH CORCON                    70:              push      CORCON
00DC1A  200E24     MOV #0xE2, W4                  71:              mov.w     #0x00E2,CorconW4
00DC1C  880224     MOV W4, CORCON                 72:              mov.w     CorconW4,CORCON
                                                  73:         ;; workW0 : in_Ref
                                                  74:    	 ;; workW1 : in_Meas
                                                  75:    	 ;; workW2 : PISTATE*
                                                  76:    	 ;; workW3 : PIPARMOUT* out
                                                  77:    
                                                  78:         ;; Err  = in_Ref - in_Meas
00DC1E  CA0000     LAC W0, A                      79:              lac       workW0,#0,A
00DC20  CA8001     LAC W1, B                      80:              lac       workW1,#0,B
00DC22  CB3000     SUB A                          81:              sub       A
00DC24  CC0004     SAC A, W4                      82:              sac       A,#0,ErrW4
                                                  83:    
00DC26  780082     MOV W2, W1                     84:              mov.w		workW2,StateptrW1
00DC28  780103     MOV W3, W2                     85:    		  mov.w     workW3,OutptrW2   
                                                  86:              
                                                  87:         ;; U  = integrator + Kp * Err * 2^NKo
00DC2A  900011     MOV [W1+2], W0                 88:              mov.w     [StateptrW1+PISTATE_integratorH],workW0
00DC2C  CA8000     LAC W0, B                      89:              lac       workW0,B                 ; AccB = integrator
00DC2E  900001     MOV [W1+0], W0                 90:              mov.w     [StateptrW1+PISTATE_integratorL],workW0
00DC30  880140     MOV W0, ACCB                   91:              mov.w     workW0,ACCBL
                                                  92:    
00DC32  9002A1     MOV [W1+4], W5                 93:              mov.w     [StateptrW1+PISTATE_kp],workW5
00DC34  C00113     MPY W4*W5, A                   94:              mpy       ErrW4*workW5,A
00DC36  C8007C     SFTAC A, #-4                   95:              sftac     A,#-NKo                  ; AccA = Kp*Err*2^NKo     
00DC38  CB0000     ADD A                          96:              add       A                        ; Sum = Sum + Kp*Err*2^NKo
00DC3A  CC0006     SAC A, W6                      97:              sac       A,UnlimitW6              ; store U before tests
                                                  98:    
                                                  99:         ;; if( U > Outmax )
                                                  100:        ;;     Out = Outmax
                                                  101:        ;; else if( U < Outmin )
                                                  102:        ;;     Out = Outmin
                                                  103:        ;; else        
                                                  104:        ;;     Out = U 
                                                  105:   
00DC3C  9001D1     MOV [W1+10], W3                106:             mov.w     [StateptrW1+PISTATE_out_Max],OutW3
00DC3E  E13003     CP W6, W3                      107:             cp        UnlimitW6,OutW3
00DC40  3C0004     BRA GT, 0xDC4A                 108:             bra       GT,jPI5             ; U > Outmax; OutW3 = Outmax
                                                  109:   
00DC42  9001E1     MOV [W1+12], W3                110:             mov.w     [StateptrW1+PISTATE_out_Min],OutW3
00DC44  E13003     CP W6, W3                      111:             cp        UnlimitW6,OutW3
00DC46  340001     BRA LE, 0xDC4A                 112:             bra       LE,jPI5             ; U < Outmin; OutW3 = Outmin
                                                  113:   
00DC48  780186     MOV W6, W3                     114:             mov.w     UnlimitW6,OutW3     ; OutW3 = U
                                                  115:   jPI5:
00DC4A  780903     MOV W3, [W2]                   116:             mov.w     OutW3,[OutptrW2]
                                                  117:   
                                                  118:        ;; Ki * Err
00DC4C  9002B1     MOV [W1+6], W5                 119:             mov.w     [StateptrW1+PISTATE_ki],workW5
00DC4E  C00113     MPY W4*W5, A                   120:             mpy       ErrW4*workW5,A              ; A = Ki * ErrW4
                                                  121:   
                                                  122:        ;; Exc = U - Out
00DC50  530303     SUB W6, W3, W6                 123:             sub.w     UnlimitW6,OutW3,UnlimitW6   ; UnlimitW6 = UnlimitW6 - OutW3
                                                  124:   
                                                  125:        ;; Ki * Err - Kc * Exc 
00DC52  9002C1     MOV [W1+8], W5                 126:             mov.w     [StateptrW1+PISTATE_kc],workW5
00DC54  C44112     MSC W5*W6, A                   127:             msc       workW5*UnlimitW6,A          ; A = A - (Kc * Exc)
                                                  128:   
                                                  129:        ;; Sum = Sum + Ki * Err - Kc * Exc 
00DC56  CB0000     ADD A                          130:             add       A
                                                  131:   
                                                  132:        ;; Store the integrator
00DC58  CC0000     SAC A, W0                      133:             sac       A,workW0
00DC5A  980090     MOV W0, [W1+2]                 134:             mov.w     workW0,[StateptrW1+PISTATE_integratorH] 
00DC5C  800110     MOV ACCA, W0                   135:             mov.w     ACCAL,workW0
00DC5E  980080     MOV W0, [W1+0]                 136:             mov.w     workW0,[StateptrW1+PISTATE_integratorL]
                                                  137:   
                                                  138:   	 ;; Return 1	  
00DC60  200010     MOV #0x1, W0                   139:   		  mov.w     #1, workW0
00DC62  F90044     POP CORCON                     140:             pop       CORCON
00DC64  060000     RETURN                         141:             return
                                                  142:   
                                                  143:             .end
---  C:/Projects/Microchip/Workspace/Inresol_Inverter/lib_src/mc_park_dspic.s  --------------------------
