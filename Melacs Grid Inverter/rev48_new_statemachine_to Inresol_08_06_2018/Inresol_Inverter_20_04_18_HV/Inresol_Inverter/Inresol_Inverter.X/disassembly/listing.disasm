                                                  18:    ; CONSEQUENTIAL DAMAGES, LOST PROFITS OR LOST DATA, COST OF PROCUREMENT OF
                                                  19:    ; SUBSTITUTE GOODS, TECHNOLOGY, SERVICES, OR ANY CLAIMS BY THIRD PARTIES
                                                  20:    ; (INCLUDING BUT NOT LIMITED TO ANY DEFENSE THEREOF), OR OTHER SIMILAR COSTS.
                                                  21:    ;*********************************************************************************
                                                  22:    
                                                  23:              .include "mc_interfaces_dspic.inc"
                                                  24:    ; Inputs:
                                                  25:    ;  ABC.a
                                                  26:    ;  ABC.b
                                                  27:    
                                                  28:    ; Outputs:
                                                  29:    ;  ALPHABETA.alpha
                                                  30:    ;  ALPHABETA.beta
                                                  31:    
                                                  32:    ; Register usage
                                                  33:              .equ workW0,  w0  ; working register
                                                  34:    	      .equ workW1,  w1  ; working register
                                                  35:    		  
                                                  36:              .equ Sq3W4,   w4  ; OneBySq3
                                                  37:              .equ CorconW4, w4 ; CORCON temp
                                                  38:    
                                                  39:              .equ aW6,    w6   ; a
                                                  40:              .equ bW7,    w7   ; b
                                                  41:              .equ betaW7, w7   ; beta replaces b
                                                  42:    		  
                                                  43:    ; Constants
                                                  44:              .equ OneBySq3,0x49E7   ; 1/sqrt(3) in 1.15 format
                                                  45:    
                                                  46:    ; Note
                                                  47:    ;  This function requires CORCON register to be setup in a certain state
                                                  48:    ;  in order to operate correctly. Due to this requirement, this function
                                                  49:    ;  will save the CORCON register on the stack in the beginning of the
                                                  50:    ;  function and restore it before the function return.
                                                  51:    ;  After saving the CORCON register, this function writes to all bits of
                                                  52:    ;  the CORCON register. Thus, for the brief duration when this function is
                                                  53:    ;  executing, the state of CORCON register may be different from its state
                                                  54:    ;  as set by the function caller. This may change the CPU core behavior with
                                                  55:    ;  respect to exception processing latency, DO loop termination, CPU interrupt
                                                  56:    ;  priority level and DSP-engine behavior.
                                                  57:    
                                                  58:    ;=================== CODE =====================
                                                  59:    
                                                  60:              .section  .text
                                                  61:              .global   _MC_TransformClarke_Assembly
                                                  62:              .global   MC_TransformClarke_Assembly
                                                  63:    
                                                  64:    _MC_TransformClarke_Assembly:
                                                  65:    MC_TransformClarke_Assembly:
                                                  66:         ;; Save CORCON, then configure as needed
00DD60  F80044     PUSH CORCON                    67:              push      CORCON
00DD62  200E24     MOV #0xE2, W4                  68:              mov.w     #0x00E2,CorconW4
00DD64  880224     MOV W4, CORCON                 69:              mov.w     CorconW4,CORCON
                                                  70:         ;; workW0 : ABC*
                                                  71:         ;; workW1 : ALPHABETA*
                                                  72:    
00DD66  249E74     MOV #0x49E7, W4                73:              mov.w     #OneBySq3,Sq3W4     ; 1/sqrt(3) in 1.15 format
                                                  74:    
                                                  75:         ;; alpha = a
00DD68  900300     MOV [W0+0], W6                 76:              mov.w     [workW0+ABC_a],aW6
00DD6A  980086     MOV W6, [W1+0]                 77:              mov.w     aW6,[workW1+ALPHABETA_alpha]		  
                                                  78:    
                                                  79:         ;; beta = a*OneBySq3 + 2*b*OneBySq3
00DD6C  C10113     MPY W4*W6, A                   80:              mpy       Sq3W4*aW6,A
00DD6E  900390     MOV [W0+2], W7                 81:              mov.w     [workW0+ABC_b],bW7
00DD70  C20112     MAC W4*W7, A                   82:              mac       Sq3W4*bW7,A
00DD72  C20112     MAC W4*W7, A                   83:              mac       Sq3W4*bW7,A
00DD74  CC0007     SAC A, W7                      84:              sac       A,betaW7
00DD76  980097     MOV W7, [W1+2]                 85:              mov.w     betaW7,[workW1+ALPHABETA_beta]
                                                  86:    		  
                                                  87:    	 ;; Return 1	  
00DD78  200010     MOV #0x1, W0                   88:    		  mov.w     #1, workW0		  
00DD7A  F90044     POP CORCON                     89:              pop       CORCON
00DD7C  060000     RETURN                         90:              return
                                                  91:              .end
