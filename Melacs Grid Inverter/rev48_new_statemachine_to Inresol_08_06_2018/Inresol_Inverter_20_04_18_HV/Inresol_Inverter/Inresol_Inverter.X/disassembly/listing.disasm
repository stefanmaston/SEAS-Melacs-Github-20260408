430:               int BSP_UART_1_Send_Data_NoBlocking(const void  *data, uint16_t length)
431:               {
00A16C  FA0008     LNK #0x8
00A16E  980720     MOV W0, [W14+4]
00A170  980731     MOV W1, [W14+6]
432:               	//
433:               	// Message sent using no-blocking method (may overflow the ring buffer)
434:               	//
435:               	// Populate a transmit ring buffer and start UART transmit
436:               	uint16_t ret;
437:               	uint8_t *p8 = (uint8_t*)data;
00A172  9000AE     MOV [W14+4], W1
00A174  780F01     MOV W1, [W14]
