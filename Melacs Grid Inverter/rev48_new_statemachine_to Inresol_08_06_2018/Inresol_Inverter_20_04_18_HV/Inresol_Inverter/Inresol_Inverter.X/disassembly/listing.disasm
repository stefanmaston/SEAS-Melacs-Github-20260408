302:               
303:               /* RX Command - Set DPLL Parameters - Frame Description
304:               Byte  0 - 'S' ASCII character (Start of Frame Cmd)
305:               Bytes 1, 2 - ASCII HEX representation of uint8_t value - the Command Code (e.g. 07 means: SET_DPLL_PARAMS)
306:               Bytes 3, 4, 5, 6 - ASCII HEX representation of uint16_t value - the Ud value from 0 to 65535, 0% - 100% (e.g. 0 means: 0%)
307:               Bytes 7, 8, 9, 10 - ASCII HEX representation of uint16_t value - the Uq value from 0 to 65535, 0% - 100% (e.g. 7FFF means: 50%)
308:               Bytes 11, 12, 13, 14 - ASCII HEX representation of uint16_t value - the Id value from 0 to 65535, 0% - 100% (e.g. BFFF means: 75%)
309:               Bytes 15, 16, 17, 18 - ASCII HEX representation of uint16_t value - the Iq value from 0 to 65535, 0% - 100% (e.g. FFFF means: 100%)
310:               Bytes 19, 20, 21, 22 - ASCII HEX representation of uint16_t value - the Omega value from 0 to 65535, 0% - 100% (e.g. FFFF means: 100%)
311:               Bytes 23, 24 - ASCII HEX representation of uint8_t value - the Incremented Frame Counter
312:               Byte 25 - 'Z' ASCII character (End of Frame)
313:               Byte 26 - <CR> control character (Carriage Return)
314:               Byte 27 - <LF> control character (Line Feed)
315:               */
316:               
317:               // RX Command - Set DPLL Parameters - ASCIIHEX & BIN Structures
318:               typedef struct __attribute__((packed)) RxCmdSetDpllParams_ASCIIHEX_s {
319:               	char		Start_of_Frame;
320:               	char		Cmd_Code[2];
321:               	char		Ud_Value[4];
322:               	char		Uq_Value[4];
323:               	char		Id_Value[4];
324:               	char		Iq_Value[4];
325:               	char		Omega_Value[4];
326:               	char		Frame_Counter[2];
327:               	char		End_of_Frame;
328:               } RxCmdSetDpllParams_ASCIIHEX_t;
329:               
330:               typedef struct __attribute__((packed)) RxCmdSetDpllParams_BIN_s {
331:               	uint16_t	Ud_Value;
