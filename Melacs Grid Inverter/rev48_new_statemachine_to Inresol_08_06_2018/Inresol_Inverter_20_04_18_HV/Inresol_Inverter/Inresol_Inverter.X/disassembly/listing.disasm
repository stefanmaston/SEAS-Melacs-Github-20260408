                                                  12:    ; EITHER EXPRESS OR IMPLIED, INCLUDING WITHOUT LIMITATION, ANY WARRANTY OF
                                                  13:    ; MERCHANTABILITY, TITLE, NON-INFRINGEMENT AND FITNESS FOR A PARTICULAR PURPOSE.
                                                  14:    ; IN NO EVENT SHALL MICROCHIP OR ITS LICENSORS BE LIABLE OR OBLIGATED UNDER
                                                  15:    ; CONTRACT, NEGLIGENCE, STRICT LIABILITY, CONTRIBUTION, BREACH OF WARRANTY, OR
                                                  16:    ; OTHER LEGAL EQUITABLE THEORY ANY DIRECT OR INDIRECT DAMAGES OR EXPENSES
                                                  17:    ; INCLUDING BUT NOT LIMITED TO ANY INCIDENTAL, SPECIAL, INDIRECT, PUNITIVE OR
                                                  18:    ; CONSEQUENTIAL DAMAGES, LOST PROFITS OR LOST DATA, COST OF PROCUREMENT OF
                                                  19:    ; SUBSTITUTE GOODS, TECHNOLOGY, SERVICES, OR ANY CLAIMS BY THIRD PARTIES
                                                  20:    ; (INCLUDING BUT NOT LIMITED TO ANY DEFENSE THEREOF), OR OTHER SIMILAR COSTS.
                                                  21:    ;*********************************************************************************
                                                  22:    
                                                  23:              .include "mc_interfaces_dspic.inc"
                                                  24:    ; Inputs:
                                                  25:    ;  SINCOS.cos
                                                  26:    ;  SINCOS.sin
                                                  27:    ;  ALPHABETA.alpha
                                                  28:    ;  ALPHABETA.beta
                                                  29:    
                                                  30:    ; Outputs:
                                                  31:    ;  DQ.d
                                                  32:    ;  DQ.q
                                                  33:    
                                                  34:    ; Register usage
                                                  35:              .equ workW0,  w0    ; working register
                                                  36:    	      .equ workW1,  w1    ; working register
                                                  37:    	      .equ workW2,  w2    ; working register
                                                  38:              .equ CorconW4,w4    ; CORCON temp
                                                  39:              .equ sinW4,   w4    ; Sine
                                                  40:              .equ cosW5,   w5    ; Cosine
                                                  41:              .equ alphaW6, w6    ; alpha
                                                  42:              .equ betaW7,  w7    ; beta
                                                  43:    
                                                  44:    ; Note
                                                  45:    ;  This function requires CORCON register to be setup in a certain state
                                                  46:    ;  in order to operate correctly. Due to this requirement, this function
                                                  47:    ;  will save the CORCON register on the stack in the beginning of the
                                                  48:    ;  function and restore it before the function return.
                                                  49:    ;  After saving the CORCON register, this function writes to all bits of
                                                  50:    ;  the CORCON register. Thus, for the brief duration when this function is
                                                  51:    ;  executing, the state of CORCON register may be different from its state
                                                  52:    ;  as set by the function caller. This may change the CPU core behavior with
                                                  53:    ;  respect to exception processing latency, DO loop termination, CPU interrupt
                                                  54:    ;  priority level and DSP-engine behavior.
                                                  55:    
                                                  56:    ;=================== CODE =====================
                                                  57:    
                                                  58:              .section  .text
                                                  59:              .global   _MC_TransformPark_Assembly
                                                  60:              .global   MC_TransformPark_Assembly
                                                  61:    
                                                  62:    _MC_TransformPark_Assembly:
                                                  63:    MC_TransformPark_Assembly:
                                                  64:         ;; Save CORCON, then configure as needed
00DD3C  F80044     PUSH CORCON                    65:              push      CORCON
00DD3E  200E24     MOV #0xE2, W4                  66:              mov.w     #0x00E2,CorconW4
00DD40  880224     MOV W4, CORCON                 67:              mov.w     CorconW4,CORCON
                                                  68:         ;; workW0 : ALPHABETA*
                                                  69:    	 ;; workW1 : SINCOS*
                                                  70:    	 ;; workW2 : DQ*
                                                  71:              
                                                  72:         ;; Get sin, cos from SINCOS structure
00DD42  900211     MOV [W1+2], W4                 73:              mov.w     [workW1+SINCOS_sin],sinW4
00DD44  900281     MOV [W1+0], W5                 74:              mov.w     [workW1+SINCOS_cos],cosW5
                                                  75:    
                                                  76:         ;; Get alpha, beta from ALPHABETA structure
00DD46  900300     MOV [W0+0], W6                 77:              mov.w     [workW0+ALPHABETA_alpha],alphaW6
00DD48  900390     MOV [W0+2], W7                 78:              mov.w     [workW0+ALPHABETA_beta],betaW7		  
                                                  79:    		  
                                                  80:         ;; d = alpha*cos(Angle) + beta*sin(Angle)
00DD4A  C20113     MPY W4*W7, A                   81:              mpy       sinW4*betaW7,A          ; beta*sin -> A
00DD4C  C40112     MAC W5*W6, A                   82:              mac       cosW5*alphaW6,A         ; add alpha*cos to A
00DD4E  CC0000     SAC A, W0                      83:              sac       A,workW0                ; store A into workW0
00DD50  980100     MOV W0, [W2+0]                 84:    		  mov.w     workW0,[workW2+DQ_d]    ; Update d
                                                  85:    
                                                  86:         ;; q = -alpha*sin(Angle) + beta*cos(Angle)
00DD52  C50113     MPY W5*W7, A                   87:              mpy       cosW5*betaW7,A          ; beta*cos -> A
00DD54  C14112     MSC W4*W6, A                   88:              msc       sinW4*alphaW6,A         ; sub alpha*sin from A
00DD56  CC0000     SAC A, W0                      89:              sac       A,workW0                ; store A into workW0
00DD58  980110     MOV W0, [W2+2]                 90:    		  mov.w     workW0,[workW2+DQ_q]    ; Update q
                                                  91:    		  
                                                  92:    	 ;; Return 1	  
00DD5A  200010     MOV #0x1, W0                   93:    		  mov.w     #1, workW0		  
00DD5C  F90044     POP CORCON                     94:              pop       CORCON
00DD5E  060000     RETURN                         95:              return
                                                  96:    
                                                  97:              .end
---  C:/Projects/Microchip/Workspace/Inresol_Inverter/lib_src/mc_invpark_dspic.s  -----------------------
                                                  1:     ;*********************************************************************************
                                                  2:     ; Copyright (c) 2013 released Microchip Technology Inc.  All rights reserved.
                                                  3:     ; Microchip licenses to you the right to use, modify, copy and distribute
