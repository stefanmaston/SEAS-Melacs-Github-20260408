83:                // This function sets the frequency of the oscillator in the tenths of Hz (0.1Hz).
84:                // In addition, this function calculates the corresponding frequency tuning word.
85:                void App_DDS_Set_Freq(uint16_t Freq)
86:                {
00B1AA  FA0002     LNK #0x2
00B1AC  780F00     MOV W0, [W14]
87:                	if(Freq > APP_SETTINGS_DDS_MAX_GEN_FREQ)
00B1AE  2028A0     MOV #0x28A, W0
00B1B0  78009E     MOV [W14], W1
00B1B2  508F80     SUB W1, W0, [W15]
00B1B4  360003     BRA LEU, 0xB1BC
