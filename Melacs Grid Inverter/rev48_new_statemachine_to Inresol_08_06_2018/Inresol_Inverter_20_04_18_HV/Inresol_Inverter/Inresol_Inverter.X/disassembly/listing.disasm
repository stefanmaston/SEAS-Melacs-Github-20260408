333:               	uint16_t	Id_Value;
334:               	uint16_t	Iq_Value;
335:               	uint16_t	Omega_Value;
336:               	uint8_t		Frame_Counter;
337:               } RxCmdSetDpllParams_BIN_t;
338:               
339:               #define RX_CMD_SET_DPLL_PARAMS_TYPE		DATA_4BYTES, DATA_4BYTES, DATA_4BYTES, DATA_4BYTES, DATA_4BYTES, DATA_2BYTES, DATA_NULL
340:               #define RX_CMD_SET_DPLL_PARAMS_SIZE		sizeof(RxCmdSetDpllParams_ASCIIHEX_t)
