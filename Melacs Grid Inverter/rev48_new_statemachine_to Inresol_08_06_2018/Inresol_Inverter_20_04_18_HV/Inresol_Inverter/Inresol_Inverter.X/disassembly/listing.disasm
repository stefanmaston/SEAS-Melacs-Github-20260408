714:               // Transmit a byte array through the UART peripheral (non-blocking)
715:               int BlockWriteUART2(const void *data, int numBytes)
716:               {
00A37A  FA0008     LNK #0x8
00A37C  980720     MOV W0, [W14+4]
00A37E  980731     MOV W1, [W14+6]
717:               	int sent = 0;
00A380  EB0000     CLR W0
00A382  780F00     MOV W0, [W14]
718:               	uint8_t *p8 = (uint8_t*)data;
00A384  9000AE     MOV [W14+4], W1
00A386  980711     MOV W1, [W14+2]
719:               
720:               	// Send until the transmit FIFO is full or out of bytes
721:               	while((sent < numBytes) && (U2STAbits.UTXBF == 0)) {
00A388  370007     BRA 0xA398
00A398  90003E     MOV [W14+6], W0
00A39A  78009E     MOV [W14], W1
00A39C  508F80     SUB W1, W0, [W15]
00A39E  3D0005     BRA GE, 0xA3AA
00A3A0  801191     MOV U2STA, W1
00A3A2  202000     MOV #0x200, W0
00A3A4  608000     AND W1, W0, W0
00A3A6  E00000     CP0 W0
00A3A8  32FFF0     BRA Z, 0xA38A
722:               		WriteUART2(*p8);
00A38A  90001E     MOV [W14+2], W0
00A38C  784010     MOV.B [W0], W0
00A38E  07FFE4     RCALL WriteUART2
723:               		p8++;
00A390  90001E     MOV [W14+2], W0
00A392  E80000     INC W0, W0
00A394  980710     MOV W0, [W14+2]
724:               		sent++;
00A396  E80F1E     INC [W14], [W14]
725:               	}
726:               	return sent;
00A3AA  78001E     MOV [W14], W0
727:               }
00A3AC  FA8000     ULNK
00A3AE  060000     RETURN
