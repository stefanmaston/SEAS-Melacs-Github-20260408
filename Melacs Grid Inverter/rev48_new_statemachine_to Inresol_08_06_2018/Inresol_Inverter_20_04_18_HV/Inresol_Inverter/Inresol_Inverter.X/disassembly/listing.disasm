00B1B6  2028A0     MOV #0x28A, W0
00B1B8  889460     MOV W0, App_DDS_Waves_Freq
00B1BA  370009     BRA 0xB1CE
89:                	else if(Freq < APP_SETTINGS_DDS_MIN_GEN_FREQ)
00B1BC  201C10     MOV #0x1C1, W0
00B1BE  78009E     MOV [W14], W1
00B1C0  508F80     SUB W1, W0, [W15]
00B1C2  3E0003     BRA GTU, 0xB1CA
90:                		App_DDS_Waves_Freq = APP_SETTINGS_DDS_MIN_GEN_FREQ;
00B1C4  201C20     MOV #0x1C2, W0
00B1C6  889460     MOV W0, App_DDS_Waves_Freq
00B1C8  370002     BRA 0xB1CE
91:                	else
92:                		App_DDS_Waves_Freq = Freq;
00B1CA  78009E     MOV [W14], W1
00B1CC  889461     MOV W1, App_DDS_Waves_Freq
93:                	Calculate_Freq_Tunes();
00B1CE  07FFE7     RCALL Calculate_Freq_Tunes
94:                }
00B1D0  FA8000     ULNK
00B1D2  060000     RETURN
