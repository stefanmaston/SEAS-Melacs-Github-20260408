141:                 #if UNUSED
142:                 void RTC_Read_Clock_(void)
143:                 {
144:                     uint8_t len;
145:                     uint8_t *ptr;
146:                     ptr = (uint8_t *) &RTCclk;  // This is a structure that will be filled with data, first seconds than minutes and so on
147:                     len = offsetof(struct RTCclk, protect); // Just write the first 7 parts skip the last (protect = 0x00 always)
148:                     
149:                     CS_RTC = 0;
150:                     SD_SPI_Enable();
151:                     
152:                     SD_SPI_Transfer(0xBF);  // Command for burst read
153:                 
154:                     do
155:                     {
156:                         // Automatically convert binary to BCD
157:                         uint8_t value = SD_SPI_Transfer(0xFF); ;
158:                         value = (value >> 4) * 10 + (value & 15);
159:                 
160:                         *ptr++ = value;
161:                     }
162:                     while(--len);
163:                 
164:                     CS_RTC = 1;
165:                 }
166:                 
167:                 void RTC_Write_Clock_(void)
168:                 {
169:                     CS_RTC = 0;
170:                 
171:                     const uint8_t *ptr;
172:                     uint8_t len;
173:                     ptr = (const uint8_t *) &RTCclk;
174:                     len = sizeof RTCclk;
175:                 
176:                     SD_SPI_Transfer(0x0F);    // Control Address 0Fh
177:                 
178:                     SD_SPI_Transfer(0x00);    // Zero the Write Protection Bit
179:                 
180:                     SD_SPI_Transfer(0x3F);    // Burst Write Command 0b00111111 (<Read/#Write><Ram/#Clock><1><1><1><1><1><Read/#Write>)
181:                 
182:                     ptr = (const uint8_t *) &RTCclk;
183:                     len = sizeof RTCclk;
184:                 
185:                 
186:                     do
187:                     {
188:                         uint8_t bin = *ptr++;
189:                         // This to automatically convert clock fields from binary to BCD
190:                         uint8_t bcd = bin;
191:                         bcd = (bcd / 10) << 4;
192:                         bcd = bcd | (bin % 10);
193:                         SD_SPI_Transfer(bcd);
194:                     }
195:                     while(--len);
196:                 
197:                     SD_SPI_Transfer(0x00);
198:                 
199:                     CS_RTC = 1;
200:                 }
201:                 #endif
202:                 
203:                 #endif
