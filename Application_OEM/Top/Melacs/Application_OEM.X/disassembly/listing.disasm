336:                 /*****************************************************************************
337:                  * SPI functions
338:                  *****************************************************************************/
339:                 #define ENC_MAX_SPI_FREQ (14000000ul)
340:                 
341:                 // ENC28J60 connect to SPI2
342:                 #define ENC_SPIBRG			(SPI3BRG)
343:                 #define ENC_SPICON			(SPI3CON)
344:                 #define ENC_SPICONbits		(SPI3CONbits)
345:                 #define ENC_SPISTATbits		(SPI3STATbits)
346:                 #define ENC_SPIBUF			(SPI3BUF)
347:                 
348:                 #define ENC_CS_TRIS			(TRISAbits.TRISA6)
349:                 #define ENC_CS_IO			(PORTAbits.RA6)
350:                 #define ENC_INT_TRIS		(TRISEbits.TRISE8)
351:                 #define ENC_INT_IO			(PORTEbits.RE8)
352:                 
353:                 void ethernet_spi_init()
354:                 {
355:                 	SpiChnOpen(SPI_CHANNEL3, SPI_OPEN_MSTEN|SPI_OPEN_SMP_END|SPI_OPEN_CKE_REV|SPI_OPEN_MODE8, PBCLK/14000000);
356:                 }
357:                 
358:                 // Set up the SPI module on the PIC for communications with the ENC424J600
359:                 void enc424j600_init()
360:                 {
361:                 	ethernet_spi_init();
362:                 
363:                 	ENC_CS_IO = 1;
364:                 	ENC_CS_TRIS = 0;		// Make the Chip Select pin an output
365:                 
366:                 	ENC_INT_IO = 0;
367:                 	ENC_INT_TRIS = 1;		// Make the INT pin an input
368:                 	ENC_INT_IO = 1;
369:                 }
370:                 
371:                 /*************************************
372:                 Mandatory functions for tcpserver
373:                 This function use by tcpserver to set/reset CS
374:                 *************************************/
375:                 
376:                 void enc_cs_pin(int set)
377:                 {
378:                 	if (set)
379:                         {
380:                 		ENC_CS_IO = 1;
381:                                 spiUnlockMutex();
382:                         }
383:                 	else
384:                         {
385:                                 spiLockMutex();
386:                                 ethernet_spi_init();
387:                 		ENC_CS_IO = 0;
388:                         }
389:                 }
390:                 
391:                 // Write data to ENC28J60
392:                 void _Spi_putc(int data)
393:                 {
394:                         //ENC_CS_IO = 1;
395:                 	/* wait until there's room in the buffer and send the byte */
396:                 	SpiChnPutC(SPI_CHANNEL3, (unsigned int)data);
397:                         //ENC_CS_IO = 0;
398:                 }
399:                 
400:                 // Read data from ENC28J60
401:                 int _Spi_getc(void)
402:                 {
403:                 	int data;
404:                         //ENC_CS_IO = 1;
405:                 	/*wait until there's data in the buffer and receive it */
406:                 	data = (int)SpiChnGetC(SPI_CHANNEL3);
407:                 	//ENC_CS_IO = 0;
408:                 	return data;
409:                 }
410:                 
411:                 #endif
