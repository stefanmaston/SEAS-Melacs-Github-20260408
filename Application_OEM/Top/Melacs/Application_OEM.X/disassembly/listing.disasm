52:                  /*
53:                  Mutex lock/unlock protection could be used for systems with more then one devices
54:                  connected to one SPI bus. For such kind of configuration define SPI_PROTECT == 1 and
55:                  make sure you are using same variable - "spi_mutex" for your spi driver too.
56:                  */
57:                  #if SPI_PROTECT == 1
58:                  	pthread_mutex_t				spi_mutex;
59:                  	#define SPI_MUTEX_INIT		pthread_mutex_init(&spi_mutex, 0);
60:                  	#define SPI_MUTEX_LOCK		pthread_mutex_lock(&spi_mutex);
61:                  	#define SPI_MUTEX_UNLOCK	pthread_mutex_unlock(&spi_mutex);
62:                  
63:                  #else
64:                  	#define SPI_MUTEX_INIT
65:                  	#define SPI_MUTEX_LOCK
66:                  	#define SPI_MUTEX_UNLOCK
67:                  
68:                  #endif
