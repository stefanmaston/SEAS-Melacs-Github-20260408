1733:                #ifdef LOG_RUN_SAMPLE
1734:                
1735:                extern void logRunSample(void)
1736:                {
1737:                	int writechars;
1738:                	struct timespec currentTime;
1739:                
1740:                	xprintf("logRun function!\n");
1741:                
1742:                	clock_gettime(CLOCK_REALTIME, &currentTime);
1743:                	xprintf("TIME %lu.%09u\n", (unsigned long)currentTime.tv_sec, (unsigned long)currentTime.tv_nsec);
1744:                
1745:                        if(currentTime.tv_sec < previousLoggedTime)
1746:                        {
1747:                            if((currentTime.tv_sec + 60) < (previousLoggedTime + SAMPLE_PERIOD))
1748:                            {
1749:                                xprintf("Not ready to log yet");
1750:                                return;
1751:                            }
1752:                        }
1753:                        else if(currentTime.tv_sec < (previousLoggedTime + SAMPLE_PERIOD))
1754:                        {
1755:                            xprintf("Not ready to log yet");
1756:                            return;
1757:                        }
1758:                
1759:                        previousLoggedTime = sc;
1760:                
1761:                        memset((void*)filenamestring, 0, MAXSTRINGLEN);
1762:                	memset((void*)buf, 0, DIRSIZE);
1763:                
1764:                        /* first create a directory and then fill it with the number of requried files */
1765:                        /* note that the execute permission on the directory is required */
1766:                	if(mkdir(DIRSTRING, S_IRWXU) == -1)
1767:                	{
1768:                            if(EEXIST == errno)
1769:                            {
1770:                                xprintf("Directory already exists, %d\n", errno);
1771:                            }
1772:                            else
1773:                            {
1774:                                xprintf("Creating directory failed, the error is, %d\n", errno);
1775:                                return;
1776:                            }
1777:                	}
1778:                	else
1779:                        {
1780:                            xprintf("mkdir ok %s\n", DIRSTRING);
1781:                        }
1782:                
1783:                        strcpy( filenamestring, DIRSTRING);
1784:                        strcat( filenamestring, LOG_FIRST);
1785:                
1786:                
1787:                        xprintf("openingx§ %s\n", filenamestring);
1788:                        if((fLogFile = open( filenamestring, O_CREAT | O_RDWR | O_APPEND, 0)) == -1)
1789:                        {
1790:                            xprintf("files opened = %d, errno = %d, files should be %d\n", fLogFile, errno, MAXOPENFILES);
1791:                            return;
1792:                        }
1793:                
1794:                        if(-1 == lseek(fLogFile, 0 , SEEK_END))
1795:                        {
1796:                            xprintf("files seek to end failed, fileno = %d, errno = %d\n", fLogFile, errno);
1797:                            return;
1798:                        }
1799:                
1800:                        write(fLogFile, "\n", sizeof(char));
1801:                
1802:                        xprintf("writing %s\n", "Pliable");
1803:                        if((writechars = write(fLogFile, "Pliable", strlen("Pliable"))) == -1)
1804:                        {
1805:                            xprintf("number of bytes written = %d, file = %d, errno = %d\n", writechars, fLogFile, errno);
1806:                            if(-1 == close(fLogFile))
1807:                            {
1808:                                xprintf("File Close failed");
1809:                            }
1810:                            return;
1811:                        }
1812:                        else
1813:                        {
1814:                            xprintf("number of bytes written = %d, file = %d\n", writechars, fLogFile);
1815:                        }
1816:                
1817:                        write(fLogFile, "\n", sizeof(char));
1818:                
1819:                        if(-1 == close(fLogFile))
1820:                        {
1821:                            xprintf("File Close failed");
1822:                            return;
1823:                        }
1824:                }
1825:                
1826:                #endif
1827:                #endif //LOGGING
