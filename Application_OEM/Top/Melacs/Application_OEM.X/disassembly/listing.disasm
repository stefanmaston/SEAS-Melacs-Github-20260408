9:                   #define	DELAY_H
10:                  
11:                  #ifdef	__cplusplus
12:                  extern "C" {
13:                  #endif
14:                      
15:                  #include <peripheral/timer.h>    
16:                  
17:                  #define GetSystemClock()    (72000000ULL) //Same as sysclk
18:                  
19:                  static inline void __attribute__((always_inline)) DelayUs(uint32_t delay_in_us ) 
20:                  {
21:                       uint32_t tWait = ( GetSystemClock() / 2000000 ) * delay_in_us;
22:                       uint32_t tStart = ReadCoreTimer();
23:                       while( ( ReadCoreTimer() - tStart ) < tWait ); 
24:                  }
25:                  
26:                  //11 = 305ns
27:                  //9 = 250ns by calculation and in practical 500ns, we need a delay of more that 250ns, but to have a buffer, its good to have 500ns
28:                  //1 = gives 350ns in practice, this should be sufficient but may be some speed optimisation could reduce this further
29:                  static inline void __attribute__((always_inline)) DelayADC()
30:                  {
31:                       uint32_t tWait = 9;
9D0229B4  24020009   ADDIU V0, ZERO, 9
9D022A10  24020009   ADDIU V0, ZERO, 9
9D022AA4  24020009   ADDIU V0, ZERO, 9
9D022AF0  24020009   ADDIU V0, ZERO, 9
32:                       uint32_t tStart = ReadCoreTimer();
9D0229BC  0F40B4CF   JAL ReadCoreTimer
9D022A18  0F40B4CF   JAL ReadCoreTimer
9D022AAC  0F40B4CF   JAL ReadCoreTimer
9D022AF8  0F40B4CF   JAL ReadCoreTimer
33:                       while( ( ReadCoreTimer() - tStart ) < tWait );
9D0229C8  0F40B4CF   JAL ReadCoreTimer
9D022A24  0F40B4CF   JAL ReadCoreTimer
9D022AB8  0F40B4CF   JAL ReadCoreTimer
9D022B04  0F40B4CF   JAL ReadCoreTimer
34:                  }
35:                  
36:                  
37:                  #define DelayNOP() asm("nop")
38:                  
39:                  #ifdef	__cplusplus
40:                  }
41:                  #endif
42:                  
43:                  #endif	/* DELAY_H */
